  {:des "[Desktop] Ins Layer (typing passthrough) - MUST come before Normal layer rules"
   :rules [:Desktop
    ;; Ins layer has no key mappings - all keys pass through by default
    ;; j from Normal enters Ins layer (in_any_layer stays 0 since Ins is passthrough)
    [:j [["layer_ins" 1] ["layer_normal" 0] ["in_any_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["layer_normal" 1]]
    ;; Block Ctrl+J in Ins mode (otherwise it types a newline)
    [{:key :j :modi {:mandatory [:control]}} :vk_none ["layer_ins" 1]]
    ;; escape exits Ins to Normal (explicit, reliable)
    [:escape [["layer_ins" 0] ["layer_normal" 1] ["in_any_layer" 0] ["shift_mirror_oneshot" 0] ["shift_oneshot" 0] {:shell "echo norm > /tmp/karabiner-layer"}] ["layer_ins" 1]]
    ;; right_control alone exits Ins to Normal
    [:right_control :right_control ["layer_ins" 1] {:alone [["layer_ins" 0] ["layer_normal" 1] ["in_any_layer" 0] ["shift_mirror_oneshot" 0] ["shift_oneshot" 0] {:shell "echo norm > /tmp/karabiner-layer"}]}]
    ;; Quote while mirror_mode active (shift held) = oneshot shift+mirror mode
    ;; Must come BEFORE plain quote rule
    [:quote [["shift_mirror_oneshot" 1]] ["mirror_mode" 1]]
    ;; Space while mirror_mode active = space + oneshot shift mode
    [:spacebar [:spacebar ["shift_oneshot" 1]] ["mirror_mode" 1]]
    ;; apostrophe: hold = shift
    [:quote :left_shift ["layer_ins" 1]]
    ;; shift keys: if shift_oneshot=1, set mirror_mode=2 (shifted mirror)
    [:left_shift [["mirror_mode" 2] ["shift_oneshot" 0]] ["shift_oneshot" 1] {:afterup [["mirror_mode" 0]]}]
    [:right_shift [["mirror_mode" 2] ["shift_oneshot" 0]] ["shift_oneshot" 1] {:afterup [["mirror_mode" 0]]}]
    ;; shift keys: default, set mirror_mode=1 (lowercase mirror)
    [:left_shift [["mirror_mode" 1]] ["layer_ins" 1] {:afterup [["mirror_mode" 0]]}]
    [:right_shift [["mirror_mode" 1]] ["layer_ins" 1] {:afterup [["mirror_mode" 0]]}]
    ;; Shift+up = backspace, Shift+down = delete
    [{:key :up_arrow :modi {:mandatory [:shift]}} :delete_or_backspace ["layer_ins" 1]]
    [{:key :down_arrow :modi {:mandatory [:shift]}} :delete_forward ["layer_ins" 1]]
    ;; [ = backspace, ] = delete
    [:open_bracket :delete_or_backspace ["layer_ins" 1]]
    [:close_bracket :delete_forward ["layer_ins" 1]]
   ]}

  {:des "[Desktop] Shift+Mirror oneshot (Shift+Quote then letter = Shift+mirrored letter)"
   :rules [:Desktop
    ;; Top row: Y U I O P → Shift+T R E W Q
    [:y [:!St ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:u [:!Sr ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:i [:!Se ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:o [:!Sw ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:p [:!Sq ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    ;; Home row: H J K L ; → Shift+G F D S A
    [:h [:!Sg ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:j [:!Sf ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:k [:!Sd ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:l [:!Ss ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:semicolon [:!Sa ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    ;; Bottom row: N M , . / → Shift+B V C X Z
    [:n [:!Sb ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:m [:!Sv ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:comma [:!Sc ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:period [:!Sx ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:slash [:!Sz ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
   ]}

  {:des "[Desktop] Mirror mode SHIFTED (mirror_mode=2) - must come before shift_oneshot"
   :rules [:Desktop
    ;; Top row: Y U I O P → Shift+T R E W Q
    [:y :!St ["mirror_mode" 2]]
    [:u :!Sr ["mirror_mode" 2]]
    [:i :!Se ["mirror_mode" 2]]
    [:o :!Sw ["mirror_mode" 2]]
    [:p :!Sq ["mirror_mode" 2]]
    ;; Home row: H J K L ; → Shift+G F D S A
    [:h :!Sg ["mirror_mode" 2]]
    [:j :!Sf ["mirror_mode" 2]]
    [:k :!Sd ["mirror_mode" 2]]
    [:l :!Ss ["mirror_mode" 2]]
    [:semicolon :!Sa ["mirror_mode" 2]]
    ;; Bottom row: N M , . / → Shift+B V C X Z
    [:n :!Sb ["mirror_mode" 2]]
    [:m :!Sv ["mirror_mode" 2]]
    [:comma :!Sc ["mirror_mode" 2]]
    [:period :!Sx ["mirror_mode" 2]]
    [:slash :!Sz ["mirror_mode" 2]]
   ]}

  {:des "[Desktop] Shift oneshot (Shift+Space then release, letter = Shift+letter)"
   :rules [:Desktop
    ;; Top row
    [:y [:!Sy ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:u [:!Su ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:i [:!Si ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:o [:!So ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:p [:!Sp ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    ;; Home row
    [:h [:!Sh ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:j [:!Sj ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:k [:!Sk ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:l [:!Sl ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:semicolon [:!Ssemicolon ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    ;; Bottom row
    [:n [:!Sn ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:m [:!Sm ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:comma [:!Scomma ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:period [:!Speriod ["shift_oneshot" 0]] ["shift_oneshot" 1]]
    [:slash [:!Sslash ["shift_oneshot" 0]] ["shift_oneshot" 1]]
   ]}

  {:des "[Desktop] Mirror mode UNSHIFTED (mirror_mode without shift held)"
   :rules [:Desktop
    ;; Top row: Y U I O P → T R E W Q
    [:y :t ["mirror_mode" 1]]
    [:u :r ["mirror_mode" 1]]
    [:i :e ["mirror_mode" 1]]
    [:o :w ["mirror_mode" 1]]
    [:p :q ["mirror_mode" 1]]
    ;; Home row: H J K L ; → G F D S A
    [:h :g ["mirror_mode" 1]]
    [:j :f ["mirror_mode" 1]]
    [:k :d ["mirror_mode" 1]]
    [:l :s ["mirror_mode" 1]]
    [:semicolon :a ["mirror_mode" 1]]
    ;; Bottom row: N M , . / → B V C X Z
    [:n :b ["mirror_mode" 1]]
    [:m :v ["mirror_mode" 1]]
    [:comma :c ["mirror_mode" 1]]
    [:period :x ["mirror_mode" 1]]
    [:slash :z ["mirror_mode" 1]]
    ;; Numbers: 6→5, 7→4, 8→3, 9→2, 0→1 (accounting for symbol/number swap)
    ;; Bare key (symbol): ^→%, &→$, *→#, (→@, )→!
    [:6 :!S5 ["mirror_mode" 1]]
    [:7 :!S4 ["mirror_mode" 1]]
    [:8 :!S3 ["mirror_mode" 1]]
    [:9 :!S2 ["mirror_mode" 1]]
    [:0 :!S1 ["mirror_mode" 1]]
    ;; Shift+key (number): 6→5, 7→4, 8→3, 9→2, 0→1
    [{:key :6 :modi {:mandatory [:shift]}} :5 ["mirror_mode" 1]]
    [{:key :7 :modi {:mandatory [:shift]}} :4 ["mirror_mode" 1]]
    [{:key :8 :modi {:mandatory [:shift]}} :3 ["mirror_mode" 1]]
    [{:key :9 :modi {:mandatory [:shift]}} :2 ["mirror_mode" 1]]
    [{:key :0 :modi {:mandatory [:shift]}} :1 ["mirror_mode" 1]]
    ;; Escape exits mirror mode without typing
    [:escape ["mirror_mode" 0] ["mirror_mode" 1]]
   ]}

  {:des "[Desktop] Normal Layer (default state, layer selector)"
   :rules [:Desktop
    ;; From base state (all layers off), right_control alone enters Normal
    ;; Note: Default on boot is punted - user needs to tap right_control to enter Normal initially
    [:right_control :right_control ["layer_normal" 0] {:alone [["layer_normal" 1] {:shell "echo norm > /tmp/karabiner-layer"}]}]
   ]}

  {:des "[Desktop] Normal Layer - Disable unmapped keys"
   :rules [:Desktop
    ;; In Normal mode, only layer selector keys should work
    ;; Disable all other letter keys to prevent accidental typing (## catches shift variants)
    ;; Active keys: j (Ins), n (Nav), m (Mouse), l (H), u (Term), h (app-specific), comma (Comma layer)
    [:##a :vk_none ["layer_normal" 1]]
    [:##b :vk_none ["layer_normal" 1]]
    [:##c :vk_none ["layer_normal" 1]]
    [:##d :vk_none ["layer_normal" 1]]
    [:##e :vk_none ["layer_normal" 1]]
    [:##f :vk_none ["layer_normal" 1]]
    [:##g :vk_none ["layer_normal" 1]]
    [:##i :vk_none ["layer_normal" 1]]
    [:##k :vk_none ["layer_normal" 1]]
    [:##o :vk_none ["layer_normal" 1]]
    [:##p :vk_none ["layer_normal" 1]]
    [:##q :vk_none ["layer_normal" 1]]
    [:##r :vk_none ["layer_normal" 1]]
    [:##s :vk_none ["layer_normal" 1]]
    [:##t :vk_none ["layer_normal" 1]]
    [:##v :vk_none ["layer_normal" 1]]
    [:##w :vk_none ["layer_normal" 1]]
    [:##x :vk_none ["layer_normal" 1]]
    [:##y :vk_none ["layer_normal" 1]]
    [:##z :vk_none ["layer_normal" 1]]
    ;; Disable brackets
    [:##open_bracket :vk_none ["layer_normal" 1]]
    [:##close_bracket :vk_none ["layer_normal" 1]]
    ;; Also disable period, semicolon, slash (not layer selectors) - ## catches shift variants
    [:##period :vk_none ["layer_normal" 1]]
    [:##semicolon :vk_none ["layer_normal" 1]]
    [:##slash :vk_none ["layer_normal" 1]]
    ;; Disable quote, numbers 6-0, backslash, hyphen (with any modifiers)
    [:##quote :vk_none ["layer_normal" 1]]
    [:##6 :vk_none ["layer_normal" 1]]
    [:##7 :vk_none ["layer_normal" 1]]
    [:##8 :vk_none ["layer_normal" 1]]
    [:##9 :vk_none ["layer_normal" 1]]
    [:##0 :vk_none ["layer_normal" 1]]
    [:##backslash :vk_none ["layer_normal" 1]]
    [:##hyphen :vk_none ["layer_normal" 1]]
    ;; Shift+layer-entry-keys disabled (bare key enters layer, shift should do nothing)
    ;; Use explicit {:modi {:mandatory [:shift]}} to match EITHER left or right shift
    [{:key :u :modi {:mandatory [:shift]}} :vk_none ["layer_normal" 1]]
    [{:key :h :modi {:mandatory [:shift]}} :vk_none ["layer_normal" 1]]
    [{:key :j :modi {:mandatory [:shift]}} :vk_none ["layer_normal" 1]]
    [{:key :l :modi {:mandatory [:shift]}} :vk_none ["layer_normal" 1]]
    [{:key :n :modi {:mandatory [:shift]}} :vk_none ["layer_normal" 1]]
    [{:key :m :modi {:mandatory [:shift]}} :vk_none ["layer_normal" 1]]
    [{:key :comma :modi {:mandatory [:shift]}} :vk_none ["layer_normal" 1]]
    [:##spacebar :vk_none ["layer_normal" 1]]
    [:##page_down :vk_none ["layer_normal" 1]]
    [:##page_up :vk_none ["layer_normal" 1]]
   ]}

  {:des "[Desktop] Block unmapped keys in all working layers (in_any_layer=1)"
   :rules [:Desktop
    ;; Pass through Ctrl+Shift+Y for Hammerspoon layer overlay (any ctrl+shift)
    [{:key :y :modi {:mandatory [:control :shift]}} :!TSy ["in_any_layer" 1]]
