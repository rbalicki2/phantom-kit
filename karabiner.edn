    [:##s :vk_none]
    [:##d :vk_none]
    [:##f :vk_none]
    [:##g :vk_none]
    [:##z :vk_none]
    [:##x :vk_none]
    [:##c :vk_none]
    [:##v :vk_none]
    [:##b :vk_none]
   ]}

  {:des "[Desktop] hk3 (Alt+F19) = show overlay"
   :rules [:!apple_internal
    [:!Of19 {:shell "/opt/homebrew/bin/hs -c 'showLayerOverlay()'"}]
   ]}

  {:des "[Desktop] Fn+hk3 (Shift+Alt+F19) = PANIC BUTTON"
   :rules [:!apple_internal
    [:!SOf19 [["dsk_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_ins_sub_mode" 0] ["dsk_return_to_layer" 0]
              {:shell "pkill warpd 2>/dev/null; osascript -e 'tell app \"System Events\" to key up command' && /opt/homebrew/bin/hs -c 'scrollStop(); hoverModeStop(); dismissHomerow()' && echo norm > /tmp/karabiner-layer && date > /tmp/panic-button-test"}]]
   ]}

  {:des "[Desktop] Page down/up to click/right click"
   :rules [:!apple_internal
    [:page_down :button1]
    [:page_up :button2]
   ]}

  {:des "[Desktop] Ctrl+N = escape (global, no state change - use panic for full reset)"
   :rules [:!apple_internal
    [{:key :n :modi {:mandatory [:right_control]}} [:escape]]
   ]}

  {:des "[Desktop] right_control alone = exit to Normal (global)"
   :rules [:!apple_internal
    ;; Exit to Ins (when dsk_return_to_layer=1, i.e. came from Ins via Ctrl+M)
    [
      {:key :right_control}
      [:right_control]
      ["dsk_return_to_layer" 1]  ;; came from Ins
      {:alone [
        :vk_none
        ["dsk_layer" 1]  ;; Ins
        ["dsk_in_modal_layer" 0]
        ["dsk_ins_sub_mode" 0]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo ins > /tmp/karabiner-layer"}
      ]}
    ]
    ;; Exit to Normal (global fallback - works from any layer including Ins)
    [
      {:key :right_control}
      [:right_control]
      {:alone [
        :vk_none
        ["dsk_layer" 0]  ;; Normal
        ["dsk_in_modal_layer" 0]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo norm > /tmp/karabiner-layer"}
      ]}
    ]
   ]}

  {:des "[Desktop] Ctrl+J = exit to Ins (all modal layers)"
   :rules [:!apple_internal
    [
      {:key :j :modi {:mandatory [:right_control]}}
      [
        ["dsk_layer" 1]  ;; Ins
        ["dsk_in_modal_layer" 0]  ;; not modal
        ["dsk_ins_sub_mode" 0]  ;; base
        ["dsk_return_to_layer" -1]  ;; N/A
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo ins > /tmp/karabiner-layer"}
      ]
      ["dsk_in_modal_layer" 1]  ;; when modal
    ]
   ]}

  ;; =====================================================================
  ;; DESKTOP MODE-SPECIFIC - Rules organized by layer
  ;; =====================================================================

  ;; =====================================================================
  ;; LAYER 0: NORMAL
  ;; =====================================================================

  {:des "[Desktop, Layer 0] Normal - Entry to other layers"
   :rules [:!apple_internal

    ;; J = enter Ins
    [
      {:key :j}
      [
        ["dsk_layer" 1]  ;; Ins
        ["dsk_in_modal_layer" 0]
        ["dsk_ins_sub_mode" 0]  ;; base
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo ins > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; Y = Ctrl+Alt+Shift+F19 (Wispr popo) + enter Ins
    [
      {:key :y}
      [
        [:!TOSf19]
        ["dsk_layer" 1]  ;; Ins
        ["dsk_in_modal_layer" 0]
        ["dsk_ins_sub_mode" 0]  ;; base
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo ins > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; 6 = F9 (TTS) + enter Ins
    [
      {:key :6}
      [
        [:f9]
        ["dsk_layer" 1]  ;; Ins
        ["dsk_in_modal_layer" 0]
        ["dsk_ins_sub_mode" 0]  ;; base
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo ins > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; Fn+hk4 = enter Nav
    [
      {:key :f21}  ;; Fn+hk4
      [
        ["dsk_layer" 2]  ;; Nav
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo n > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; N = escape (stays in Normal)
    [{:key :n} [:escape] ["dsk_layer" 0]]

    ;; M = enter Label mode, trigger Homerow
    [
      {:key :m}
      [
        ["dsk_layer" 13]  ;; Label
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" 0]  ;; returns to Normal
        [:!COSo]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow keep --scroll-timer reset --hover-mode reset --held-modifiers reset && echo label > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; Fn+M = enter Grid mode, start warpd
    [
      {:key :f5 :modi {:mandatory [:left_option]}}  ;; Fn+M
      [
        ["dsk_layer" 28]  ;; Grid
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "pkill -9 warpd 2>/dev/null; /usr/local/bin/warpd --grid -c /Users/rbalicki/code/voicemode/warpd.conf & echo grid > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; I = enter Admin layer
    [
      {:key :i}
      [
        ["dsk_layer" 9]  ;; Admin
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo i > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; Comma = enter Comma layer
    [
      {:key :comma}
      [
        ["dsk_layer" 6]  ;; Comma
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo comma > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; L = enter L layer
    [
      {:key :l}
      [
        ["dsk_layer" 7]  ;; L
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo l > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

    ;; U = enter Term layer (focuses iTerm)
    [
      {:key :u}
      [
        ["dsk_layer" 8]  ;; Term
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/term-layer-enter.sh"}
      ]
      ["dsk_layer" 0]
    ]

    ;; hk4 = enter In-App Nav layer
    [
      {:key :f20 :modi {:mandatory [:left_option]}}  ;; hk4 (Alt+F20)
      [
        ["dsk_layer" 10]  ;; InApp
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo inapp > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]

   ]}

  {:des "[Desktop, Layer 0] Normal - App-specific H key (Chrome)"
   :rules [:!apple_internal :Chrome
    [
      {:key :h}
      [
        ["dsk_layer" 3]  ;; Chrome
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo chrome > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]
   ]}

  {:des "[Desktop, Layer 0] Normal - App-specific H key (VS Code)"
   :rules [:!apple_internal :VSCode
    [
      {:key :h}
      [
        ["dsk_layer" 4]  ;; VSCode
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo vscode > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]
   ]}

  {:des "[Desktop, Layer 0] Normal - App-specific H key (iTerm/TMUX)"
   :rules [:!apple_internal :iTerm
    ;; h in Normal sends Control+A (tmux prefix) and enters tmux layer
    [
      {:key :h}
      [
        [:!Ta]
        ["dsk_layer" 5]  ;; TMUX
        ["dsk_in_modal_layer" 1]
        ["dsk_ins_sub_mode" -1]
        ["dsk_return_to_layer" -1]
        {:shell "/Users/rbalicki/code/voicemode/cleanup-external-state.sh --warpd reset --homerow reset --scroll-timer reset --hover-mode reset --held-modifiers reset && echo tmux > /tmp/karabiner-layer"}
      ]
      ["dsk_layer" 0]
    ]
   ]}

  {:des "[Desktop, Layer 0] Normal - Disable unmapped RHS keys"
   :rules [:!apple_internal
    ;; In Normal mode, only layer selector keys should work (LHS keys already disabled globally)
    ;; Active RHS keys: j (Ins), n (escape), m (Label), i (Admin), comma (Comma), l (L), u (Term), h (app-specific), 6 (TTS), y (Wispr)
    ;; Disable unused RHS keys (## catches any modifiers)
    [:##k :vk_none ["dsk_layer" 0]]
    [:##o :vk_none ["dsk_layer" 0]]
    [:##p :vk_none ["dsk_layer" 0]]
    [:##open_bracket :vk_none ["dsk_layer" 0]]
    [:##close_bracket :vk_none ["dsk_layer" 0]]
    [:##period :vk_none ["dsk_layer" 0]]
    [:##semicolon :vk_none ["dsk_layer" 0]]
    [:##slash :vk_none ["dsk_layer" 0]]
    [:##quote :vk_none ["dsk_layer" 0]]
    [:##7 :vk_none ["dsk_layer" 0]]
    [:##8 :vk_none ["dsk_layer" 0]]
    [:##9 :vk_none ["dsk_layer" 0]]
    [:##0 :vk_none ["dsk_layer" 0]]
    [:##backslash :vk_none ["dsk_layer" 0]]
    [:##hyphen :vk_none ["dsk_layer" 0]]
    ;; Shift+layer-entry-keys disabled (bare key enters layer, shift should do nothing)
    [{:key :u :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :h :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :j :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :l :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :n :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :m :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :comma :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [:##spacebar :vk_none ["dsk_layer" 0]]
    ;; page_down/page_up handled by global rule (maps to clicks) - no need to disable here
   ]}

  ;; =====================================================================
  ;; HIGHER LAYER RULES (organized by layer)
  ;; =====================================================================

  ;; =====================================================================
  ;; LAYER 1: INS (typing mode)
  ;; =====================================================================
  ;; Submodes: 0=base, 1=shift_mirror_oneshot, 2=shift_oneshot, 3=rcmd_h (delete), 4=rcmd_n (select)

  ;; --- Submode 1: shift_mirror_oneshot (numbers must come before number swap rules) ---
  {:des "[Desktop, Layer 1, Submode 1] Shift+mirror oneshot numbers"
   :rules [:!apple_internal
    [{:key :6} [[:5] ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [{:key :7} [[:4] ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [{:key :8} [[:3] ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [{:key :9} [[:2] ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [{:key :0} [[:1] ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
   ]}

  ;; --- Submode 0: base Ins rules ---
  {:des "[Desktop, Layer 1, Submode 0] Numbers to symbols (RHS 6-0)"
   :rules [:!apple_internal
    [{:key :6 :modi {:optional [:caps_lock]}} [:!S6] ["dsk_layer" 1]]
    [{:key :7 :modi {:optional [:caps_lock]}} [:!S7] ["dsk_layer" 1]]
    [{:key :8 :modi {:optional [:caps_lock]}} [:!S8] ["dsk_layer" 1]]
    [{:key :9 :modi {:optional [:caps_lock]}} [:!S9] ["dsk_layer" 1]]
    [{:key :0 :modi {:optional [:caps_lock]}} [:!S0] ["dsk_layer" 1]]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} [:6] ["dsk_layer" 1]]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} [:7] ["dsk_layer" 1]]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} [:8] ["dsk_layer" 1]]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} [:9] ["dsk_layer" 1]]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} [:0] ["dsk_layer" 1]]
   ]}

  {:des "[Desktop, Layer 1, Submode 0] Shift+up/down = square brackets"
   :rules [:!apple_internal
    [{:key :up_arrow :modi {:mandatory [:shift]}} :open_bracket ["dsk_layer" 1]]
    [{:key :down_arrow :modi {:mandatory [:shift]}} :close_bracket ["dsk_layer" 1]]
   ]}

  {:des "[Desktop, Layer 1, Submode 0] Backslash = tab"
   :rules [:!apple_internal
    [:backslash :tab ["dsk_layer" 1]]
   ]}

  ;; --- Submode 3: rcmd+H chord (delete) ---
  {:des "[Desktop, Layer 1, Submode 3] rcmd+H chord (delete)"
   :rules [:!apple_internal
    ;; rcmd+H sets rcmd_h_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :h :modi {:mandatory [:right_command]}} [{:shell ":"} ["dsk_ins_sub_mode" 3]] ["dsk_layer" 1] {:afterup [["dsk_ins_sub_mode" 0]]}]
    ;; While rcmd_h_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!Odelete_or_backspace ["dsk_ins_sub_mode" 3]]      ;; J = del word left
    [{:key :k :modi {:mandatory [:right_command]}} :!Odelete_forward ["dsk_ins_sub_mode" 3]]          ;; K = del word right
    [{:key :m :modi {:mandatory [:right_command]}} :!Cdelete_or_backspace ["dsk_ins_sub_mode" 3]]     ;; M = del to line start
    [{:key :comma :modi {:mandatory [:right_command]}} :!Tk ["dsk_ins_sub_mode" 3]]                   ;; , = del to line end
    [{:key :up_arrow :modi {:mandatory [:right_command]}} :delete_or_backspace ["dsk_ins_sub_mode" 3]] ;; up = del char left
    [{:key :down_arrow :modi {:mandatory [:right_command]}} :delete_forward ["dsk_ins_sub_mode" 3]]   ;; down = del char right
   ]}

  ;; --- Submode 4: rcmd+N chord (select) ---
  {:des "[Desktop, Layer 1, Submode 4] rcmd+N chord (select)"
   :rules [:!apple_internal
    ;; rcmd+N sets rcmd_n_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :n :modi {:mandatory [:right_command]}} [{:shell ":"} ["dsk_ins_sub_mode" 4]] ["dsk_layer" 1] {:afterup [["dsk_ins_sub_mode" 0]]}]
    ;; While rcmd_n_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!SOleft_arrow ["dsk_ins_sub_mode" 4]]             ;; J = sel word left
    [{:key :k :modi {:mandatory [:right_command]}} :!SOright_arrow ["dsk_ins_sub_mode" 4]]            ;; K = sel word right
