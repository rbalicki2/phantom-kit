    [:##k :vk_none ["in_modal" 1]]
    [:##l :vk_none ["in_modal" 1]]
    [:##m :vk_none ["in_modal" 1]]
    [:##n :vk_none ["in_modal" 1]]
    [:##o :vk_none ["in_modal" 1]]
    [:##p :vk_none ["in_modal" 1]]
    [:##q :vk_none ["in_modal" 1]]
    [:##r :vk_none ["in_modal" 1]]
    [:##s :vk_none ["in_modal" 1]]
    [:##t :vk_none ["in_modal" 1]]
    [:##u :vk_none ["in_modal" 1]]
    [:##v :vk_none ["in_modal" 1]]
    [:##w :vk_none ["in_modal" 1]]
    [:##x :vk_none ["in_modal" 1]]
    [:##y :vk_none ["in_modal" 1]]
    [:##z :vk_none ["in_modal" 1]]
    [:##period :vk_none ["in_modal" 1]]
    [:##semicolon :vk_none ["in_modal" 1]]
    [:##slash :vk_none ["in_modal" 1]]
    [:##comma :vk_none ["in_modal" 1]]
    [:##quote :vk_none ["in_modal" 1]]
    [:##6 :vk_none ["in_modal" 1]]
