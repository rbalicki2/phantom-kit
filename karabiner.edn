    [:!Of3 [["dsk_ins_sub_mode" 1]] ["dsk_layer" 1]]
    ;; Fn+letter in shift_mirror_oneshot → uppercase mirrored letter (must be before regular Fn+letter rules)
    [:f15 [:!St ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+Y → T
    [:f16 [:!Sr ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+U → R
    [:f17 [:!Se ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+I → E
    [:f18 [:!Sw ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+O → W
    [:f19 [:!Sq ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+P → Q
    [:f22 [:!Sg ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+H → G
    [:f23 [:!Sf ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+J → F
    [:f24 [:!Sd ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+K → D
    [:!Of1 [:!Ss ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+L → S
    [:!Of2 [:!Sa ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+; → A
    [:!Of4 [:!Sb ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+N → B
    [:!Of5 [:!Sv ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+M → V
    [:!Of6 [:!Sc ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+, → C
    [:!Of7 [:!Sx ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+. → X
    [:!Of8 [:!Sz ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+/ → Z
    ;; Fn+symbols in shift_mirror_oneshot
    [:f12 [:!Sequal_sign ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+hyphen (F12) → +
    [:!Of9 [:backslash ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+Up → \
    [:!Of10 [:grave_accent_and_tilde ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+Down → `
    [:!Of11 [:!Squote ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+[ → "
    [:!Of12 [:!Sgrave_accent_and_tilde ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+] → ~
    ;; Fn+numbers in shift_mirror_oneshot → mirrored digit (Kinesis Fn+N sends F(N+1))
    [:f7 [:5 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+6 (F7) → 5
    [:f8 [:4 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+7 (F8) → 4
    [:f9 [:3 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+8 (F9) → 3
    [:f10 [:2 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+9 (F10) → 2
    [:f11 [:1 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]  ;; Fn+0 (F11) → 1
    ;; Top row: Fn+Y/U/I/O/P → t/r/e/w/q
    [:f15 :t ["dsk_layer" 1]]  ;; Fn+Y
    [:f16 :r ["dsk_layer" 1]]  ;; Fn+U
    [:f17 :e ["dsk_layer" 1]]  ;; Fn+I
    [:f18 :w ["dsk_layer" 1]]  ;; Fn+O
    [:f19 :q ["dsk_layer" 1]]  ;; Fn+P
    ;; Middle row: Fn+H/J/K/L/; → g/f/d/s/a
    [:f22 :g ["dsk_layer" 1]]  ;; Fn+H
    [:f23 :f ["dsk_layer" 1]]  ;; Fn+J
    [:f24 :d ["dsk_layer" 1]]  ;; Fn+K
    [:!Of1 :s ["dsk_layer" 1]]  ;; Fn+L
    [:!Of2 :a ["dsk_layer" 1]]  ;; Fn+;
    ;; Bottom row: Fn+N/M/,/./slash → b/v/c/x/z
    [:!Of4 :b ["dsk_layer" 1]]  ;; Fn+N
    [:!Of5 :v ["dsk_layer" 1]]  ;; Fn+M
    [:!Of6 :c ["dsk_layer" 1]]  ;; Fn+,
    [:!Of7 :x ["dsk_layer" 1]]  ;; Fn+.
    [:!Of8 :z ["dsk_layer" 1]]  ;; Fn+/
    ;; Fn+numbers → mirrored symbols (Kinesis Fn+N sends F(N+1))
    [:f7 :!S5 ["dsk_layer" 1]]  ;; Fn+6 (F7) → %
    [:f8 :!S4 ["dsk_layer" 1]]  ;; Fn+7 (F8) → $
    [:f9 :!S3 ["dsk_layer" 1]]  ;; Fn+8 (F9) → #
    [:f10 :!S2 ["dsk_layer" 1]]  ;; Fn+9 (F10) → @
    [:f11 :!S1 ["dsk_layer" 1]]  ;; Fn+0 (F11) → !
    ;; Symbols
    [:f20 :!Stab ["dsk_layer" 1]]  ;; Fn+backslash (F20) → Shift+Tab
    ;; F12 (Fn+hyphen) passes through naturally
    [:!Of9 :!Sopen_bracket ["dsk_layer" 1]]  ;; Fn+Up → {
    [:!Of10 :!Sclose_bracket ["dsk_layer" 1]]  ;; Fn+Down → }
    ;; Fn+[ unmapped (passes through as backspace via base [ = backspace rule)
    [:!Of12 :!Sgrave_accent_and_tilde ["dsk_layer" 1]]  ;; Fn+] → ~ (tilde)
   ]}

