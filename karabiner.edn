    ;; Enter = Cmd+Enter (exits layer)
    [:return_or_enter [:!Creturn_or_enter ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 7]]
   ]}

  {:des "[Global] Block unmapped keys in all modal layers (dsk_in_modal_layer=1)"
   :rules [:!apple_internal
