  {:des "[Desktop] In-App Nav - App/Window Switcher Sub-modes"
   :rules [:!apple_internal
    ;; Up = Enter app switcher (hold Cmd, press Tab)
    ;; IMPORTANT: Must clear layer_inapp so in-app rules don't match while in app switcher
    [:up_arrow [{:shell "osascript -e 'tell app \"System Events\" to key down command' -e 'tell app \"System Events\" to keystroke tab'"}
                  ["dsk_layer" 11]] ["dsk_layer" 10]]
    ;; Down = Enter window switcher (hold Cmd, press `)
    ;; IMPORTANT: Must clear layer_inapp so in-app rules don't match while in window switcher
    [:down_arrow [{:shell "osascript -e 'tell app \"System Events\" to key down command' -e 'tell app \"System Events\" to keystroke \"`\"'"}
                ["dsk_layer" 12]] ["dsk_layer" 10]]
    ;; === App Switcher sub-mode ===
    ;; J = Tab (next app)
    [:j {:shell "osascript -e 'tell app \"System Events\" to keystroke tab'"} ["dsk_layer" 11]]
    ;; K = Shift+Tab (prev app)
    [:k {:shell "osascript -e 'tell app \"System Events\" to keystroke tab using shift down'"} ["dsk_layer" 11]]
    ;; Enter = Select and exit switcher, press Enter, return to Normal
    [:return_or_enter [:return_or_enter
                       ["dsk_in_modal_layer" 0] ["dsk_layer" 0]
                       {:shell "osascript -e 'tell app \"System Events\" to key up command' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 11]]
    ;; right_control = Cancel and exit switcher
    [:right_control [["dsk_in_modal_layer" 0] ["dsk_layer" 0]
                     {:shell "osascript -e 'tell app \"System Events\" to key up command' -e 'tell app \"System Events\" to key code 53' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 11]]
    ;; === Window Switcher sub-mode ===
    ;; J = ` (next window)
    [:j {:shell "osascript -e 'tell app \"System Events\" to keystroke \"`\"'"} ["dsk_layer" 12]]
    ;; K = Shift+` (prev window)
    [:k {:shell "osascript -e 'tell app \"System Events\" to keystroke \"`\" using shift down'"} ["dsk_layer" 12]]
    ;; Enter = Select and exit switcher, press Enter
    [:return_or_enter [:return_or_enter
                       ["dsk_in_modal_layer" 0] ["dsk_layer" 0]
