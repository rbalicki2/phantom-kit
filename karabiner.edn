;; Goku config - 1:1 conversion of karabiner.json
;; Run `goku` after editing to regenerate karabiner.json
;;
;; Modifier key legend:
;;   ! = mandatory modifier
;;   # = optional modifier
;;   C = left_command, Q = right_command
;;   T = left_control (NOT right_control - use full form for that)
;;   O = left_option,  E = right_option
;;   S = left_shift,   R = right_shift
;;   W = fn
;;
;; ## = :optional ["any"]
;; For right_control, use: {:key :x :modi {:mandatory [:right_control]}}

{
 :profiles {
  :Default {
   :default true
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
  :None {
   :default false
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
 }

 ;; Device definitions for conditional rules
 ;; :apple_internal = MacBook built-in keyboard (rules with :!apple_internal apply to external keyboards only)
 :devices {
  :apple_internal [{:vendor_id 1452 :product_id 835 :is_keyboard true}]
  :trackball [{:vendor_id 10730 :product_id 258 :is_pointing_device true}]
  :logitech [{:vendor_id 1133 :product_id 45921 :is_keyboard true :is_pointing_device true}]
 }

 :applications {
  :iTerm ["com.googlecode.iterm2"]
  :Chrome ["com.google.Chrome"]
  :VSCode ["com.microsoft.VSCode"]
 }

 :simlayers {
 }

 ;; Templates reduce repetition in shell commands
 ;; Usage: [:layer "norm"] expands to {:shell "echo norm > /tmp/karabiner-layer"}
 :templates {
  ;; Layer indicator (writes to /tmp/karabiner-layer for SwiftBar/Hammerspoon)
  :layer "echo %s > /tmp/karabiner-layer"
  ;; App launching
  :open-norm "open -a '%s' && echo norm > /tmp/karabiner-layer"
  ;; Git/terminal typing (Term layer) - sends Ctrl+C first, exits to Ins mode
  :type-ins "osascript -e 'tell app \"System Events\" to key code 8 using control down' -e 'tell app \"System Events\" to keystroke \"%s\"' && echo ins > /tmp/karabiner-layer"
  :type-enter-ins "osascript -e 'tell app \"System Events\" to key code 8 using control down' -e 'tell app \"System Events\" to keystroke \"%s\"' -e 'tell app \"System Events\" to key code 36' && echo ins > /tmp/karabiner-layer"
  ;; Chrome tab by index
  :chrome-tab "osascript -e 'tell application \"Google Chrome\" to set active tab index of front window to %s' && echo norm > /tmp/karabiner-layer"
  ;; Chrome profile switching
  :chrome-profile "/Users/rbalicki/code/voicemode/chrome-tab.sh %s && echo norm > /tmp/karabiner-layer"
 }

 :main [

  ;; =====================================================================
  ;; STATE MACHINE - 3 VARIABLES ONLY
  ;; =====================================================================
  ;;
  ;; Variables:
  ;;   mode     - Current layer (0=Normal, 1=Ins, 2+=modal layers)
  ;;   in_modal - Is mode >= 2? (0=no, 1=yes) - for "block all keys" rules
  ;;   submode  - Overlay state within a mode (0=none, 1-4=oneshot/chord modes)
  ;;
  ;; Mode values:
  ;;   0  = Normal (layer selector, most keys disabled)
  ;;   1  = Ins (typing passthrough)
  ;;   2  = Nav
  ;;   3  = Chrome
  ;;   4  = VSCode
  ;;   5  = TMUX
  ;;   6  = Comma
  ;;   7  = L (base)
  ;;   8  = Term
  ;;   9  = Admin
  ;;   10 = InApp
  ;;   11 = AppSwitcher
  ;;   12 = WindowSwitcher
  ;;   13 = Mouse
  ;;   14 = L-Cmd, 15 = L-Cmd-Shift
  ;;   16 = L-Ctrl, 17 = L-Ctrl-Shift
  ;;   18 = L-CtrlCmd, 19 = L-CtrlCmd-Shift
  ;;   20 = L-CtrlAlt, 21 = L-CtrlAlt-Shift
  ;;   22 = L-Alt, 23 = L-Alt-Shift
  ;;   24 = L-AltCmd, 25 = L-AltCmd-Shift
  ;;   26 = L-Hyper, 27 = L-Hyper-Shift
  ;;
  ;; Submode values (overlay on mode=1 Ins):
  ;;   0 = None
  ;;   1 = shift_mirror_oneshot
  ;;   2 = shift_oneshot
  ;;   3 = rcmd_h_mode (delete chord)
  ;;   4 = rcmd_n_mode (select chord)
  ;;
  ;; Transitions:
  ;;   → Normal: ["mode" 0] ["in_modal" 0] ["submode" 0]
  ;;   → Ins:    ["mode" 1] ["in_modal" 0] ["submode" 0]
  ;;   → Modal:  ["mode" N] ["in_modal" 1]
  ;;
  ;; ALWAYS write layer name to /tmp/karabiner-layer for SwiftBar
  ;; =====================================================================

  ;; =====================================================================
  ;; NONE PROFILE - Empty escape hatch (dummy rule to make Goku create it)
  ;; =====================================================================

  {:des "None profile placeholder"
   :rules [:None
    ;; Map an unused key to itself so Goku creates this profile
    [:non_us_backslash :non_us_backslash]
   ]}

  ;; =====================================================================
  ;; ALL PROFILES - Common rules (no profile condition)
  ;; =====================================================================

  {:des "Caps lock to control/escape"
   :rules [
    [:##caps_lock :left_control nil {:alone :escape}]
   ]}

  {:des "Cmd+PageUp = Escape (global)"
   :rules [
    [:!Cpage_up :escape]
    [:!Qpage_up :escape]
   ]}

  {:des "hk3 (Alt+F19) = show overlay"
   :rules [
    [:!Of19 {:shell "/opt/homebrew/bin/hs -c 'showLayerOverlay()'"}]
   ]}

  {:des "Fn+hk3 (Shift+Alt+F19) = PANIC BUTTON - reset all state"
   ;; Resets to Normal mode (mode=0, in_modal=0, submode=0)
   ;; Also kills warpd and dismisses Homerow labels
   ;; IMPORTANT: Only ONE shell command runs per rule, so combine all shell ops into one!
   :rules [
    [:!SOf19 [["mode" 0] ["in_modal" 0] ["submode" 0] ["return_to_layer" 0]
              {:shell "pkill warpd 2>/dev/null; osascript -e 'tell app \"System Events\" to key up command' && /opt/homebrew/bin/hs -c 'scrollStop(); hoverModeStop(); dismissHomerow()' && echo norm > /tmp/karabiner-layer && date > /tmp/panic-button-test"}]]
   ]}

  {:des "Fn+hk4 (F21) = enter Nav layer from Normal"
   :rules [:!apple_internal
    [:f21 [["mode" 2] ["in_modal" 1] {:shell "echo n > /tmp/karabiner-layer"}] ["mode" 0]]
   ]}

  {:des "Shift+mirror oneshot numbers (must come before number swap)"
   :rules [
    ;; RHS numbers in shift_mirror_oneshot: mirror to LHS position, output digit
    [:6 [:5 ["submode" 0]] ["submode" 1]]
    [:7 [:4 ["submode" 0]] ["submode" 1]]
    [:8 [:3 ["submode" 0]] ["submode" 1]]
    [:9 [:2 ["submode" 0]] ["submode" 1]]
    [:0 [:1 ["submode" 0]] ["submode" 1]]
   ]}

  {:des "Exchange numbers and symbols (laptop only)"
   :rules [:apple_internal
    [{:key :1 :modi {:optional [:caps_lock]}} :!S1]
    [{:key :2 :modi {:optional [:caps_lock]}} :!S2]
    [{:key :3 :modi {:optional [:caps_lock]}} :!S3]
    [{:key :4 :modi {:optional [:caps_lock]}} :!S4]
    [{:key :5 :modi {:optional [:caps_lock]}} :!S5]
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0]
    [{:key :1 :modi {:mandatory [:shift] :optional [:caps_lock]}} :1]
    [{:key :2 :modi {:mandatory [:shift] :optional [:caps_lock]}} :2]
    [{:key :3 :modi {:mandatory [:shift] :optional [:caps_lock]}} :3]
    [{:key :4 :modi {:mandatory [:shift] :optional [:caps_lock]}} :4]
    [{:key :5 :modi {:mandatory [:shift] :optional [:caps_lock]}} :5]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0]
   ]}

  {:des "Numbers to symbols (Desktop RHS 6-0, Ins mode only)"
   :rules [:!apple_internal
    ;; Bare number → symbol (only in Ins mode where typing happens)
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6 ["mode" 1]]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7 ["mode" 1]]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8 ["mode" 1]]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9 ["mode" 1]]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0 ["mode" 1]]
    ;; Shift+number → digit (like laptop)
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6 ["mode" 1]]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7 ["mode" 1]]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8 ["mode" 1]]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9 ["mode" 1]]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0 ["mode" 1]]
   ]}

  {:des "Shift+up/down = square brackets (Desktop Ins mode)"
   :rules [:!apple_internal
    [{:key :up_arrow :modi {:mandatory [:shift]}} :open_bracket ["mode" 1]]
    [{:key :down_arrow :modi {:mandatory [:shift]}} :close_bracket ["mode" 1]]
   ]}

  {:des "Brackets to command+bracket (only in working layers)"
   :rules [
    [{:key :open_bracket :modi {:optional [:caps_lock]}} :!Copen_bracket ["in_modal" 1]]
    [{:key :close_bracket :modi {:optional [:caps_lock]}} :!Cclose_bracket ["in_modal" 1]]
    ;; Cmd+bracket → bare bracket (only in working layers, blocked in Normal)
    [{:key :open_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :open_bracket ["in_modal" 1]]
    [{:key :close_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :close_bracket ["in_modal" 1]]
    ;; Shift+brackets have no special mapping (pass through naturally)
   ]}

  {:des "Backslash in Ins mode"
   :rules [
    ;; backslash = tab in Ins mode
    [:backslash :tab ["mode" 1]]
   ]}

  ;; Backslash/pipe pass through naturally (no swap)

  {:des "Left shift to open paren when alone (laptop only)"
   :rules [:apple_internal
    [:##left_shift :left_shift ["in_modal" 1] {:alone :!S9}]
   ]}

  {:des "Right shift to close paren when alone (laptop only)"
   :rules [:apple_internal
    [:##right_shift :right_shift ["in_modal" 1] {:alone :!S0}]
   ]}

  ;; =====================================================================
  ;; DESKTOP ONLY
  ;; =====================================================================

  {:des "[Desktop] Disable LHS keys and arrows"
   :rules [:!apple_internal
    [:##grave_accent_and_tilde :vk_none]  ;; physical backtick
    [:##non_us_backslash :vk_none]  ;; § key
    [:##left_arrow :vk_none]
    [:##right_arrow :vk_none]
    [:##q :vk_none]
    [:##w :vk_none]
    [:##e :vk_none]
    [:##r :vk_none]
    [:##t :vk_none]
    [:##a :vk_none]
    [:##s :vk_none]
    [:##d :vk_none]
    [:##f :vk_none]
    [:##g :vk_none]
    [:##z :vk_none]
    [:##x :vk_none]
    [:##c :vk_none]
    [:##v :vk_none]
    [:##b :vk_none]
   ]}

  {:des "[Desktop] L-Cmd click handling (must come before generic click rules)"
   :rules [:!apple_internal
    ;; In L-Cmd mode: page_down/up = Cmd+click (exits to Normal)
    [:page_down [["mode" 0] ["in_modal" 0] {:shell "echo norm > /tmp/karabiner-layer"} {:pkey :button1 :modi [:left_command]}] ["mode" 14]]
    [:page_up [["mode" 0] ["in_modal" 0] {:shell "echo norm > /tmp/karabiner-layer"} {:pkey :button2 :modi [:left_command]}] ["mode" 14]]
   ]}

  {:des "[Desktop] Page down/up to click/right click"
   :rules [:!apple_internal
    ;; Generic click - L-Cmd handles its own (rule above)
    ;; No ## so Cmd+PageUp can still trigger escape rule
    [:page_down :button1]
    [:page_up :button2]
   ]}

  {:des "[Desktop] Right command + brackets to ctrl-tab navigation"
   :rules [:!apple_internal
    [{:key :open_bracket :modi {:mandatory [:right_command]}} :!TStab]
    [{:key :close_bracket :modi {:mandatory [:right_command]}} :!Ttab]
   ]}

  {:des "[Desktop] Right control + brackets to backspace/delete"
   :rules [:!apple_internal
    [{:key :open_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_or_backspace :modi []}]
    [{:key :close_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_forward :modi []}]
   ]}

  
  {:des "[Desktop] rcmd+H chord (delete) - Ins mode only"
   :rules [:!apple_internal
    ;; rcmd+H sets rcmd_h_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :h :modi {:mandatory [:right_command]}} [{:shell ":"} ["submode" 3]] ["mode" 1] {:afterup [["submode" 0]]}]
    ;; While rcmd_h_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!Odelete_or_backspace ["submode" 3]]      ;; J = del word left
    [{:key :k :modi {:mandatory [:right_command]}} :!Odelete_forward ["submode" 3]]          ;; K = del word right
    [{:key :m :modi {:mandatory [:right_command]}} :!Cdelete_or_backspace ["submode" 3]]     ;; M = del to line start
    [{:key :comma :modi {:mandatory [:right_command]}} :!Tk ["submode" 3]]                   ;; , = del to line end
    [{:key :up_arrow :modi {:mandatory [:right_command]}} :delete_or_backspace ["submode" 3]] ;; up = del char left
    [{:key :down_arrow :modi {:mandatory [:right_command]}} :delete_forward ["submode" 3]]   ;; down = del char right
   ]}

  {:des "[Desktop] rcmd+N chord (select) - Ins mode only"
   :rules [:!apple_internal
    ;; rcmd+N sets rcmd_n_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :n :modi {:mandatory [:right_command]}} [{:shell ":"} ["submode" 4]] ["mode" 1] {:afterup [["submode" 0]]}]
    ;; While rcmd_n_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!SOleft_arrow ["submode" 4]]             ;; J = sel word left
    [{:key :k :modi {:mandatory [:right_command]}} :!SOright_arrow ["submode" 4]]            ;; K = sel word right
    [{:key :m :modi {:mandatory [:right_command]}} :!SCleft_arrow ["submode" 4]]             ;; M = sel to line start
    [{:key :comma :modi {:mandatory [:right_command]}} :!SCright_arrow ["submode" 4]]        ;; , = sel to line end
    [{:key :up_arrow :modi {:mandatory [:right_command]}} :!Sleft_arrow ["submode" 4]]       ;; up = sel char left
    [{:key :down_arrow :modi {:mandatory [:right_command]}} :!Sright_arrow ["submode" 4]]    ;; down = sel char right
   ]}

  {:des "[Desktop] Arrow navigation with right command (Ins mode only)"
   :rules [:!apple_internal
    ;; right_command + j = option + left (word left)
    [{:key :j :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:right_option]} ["mode" 1]]
    ;; right_command + k = option + right (word right)
    [{:key :k :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:right_option]} ["mode" 1]]
    ;; right_command + m = command + left (line start)
    [{:key :m :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:left_command]} ["mode" 1]]
    ;; right_command + comma = command + right (line end)
    [{:key :comma :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:left_command]} ["mode" 1]]
    ;; right_command + up = left
    [{:key :up_arrow :modi {:mandatory [:right_command] :optional [:any]}} :left_arrow ["mode" 1]]
    ;; right_command + down = right
    [{:key :down_arrow :modi {:mandatory [:right_command] :optional [:any]}} :right_arrow ["mode" 1]]
   ]}

  {:des "[Desktop] Disable backspace and delete keys"
   :rules [:!apple_internal
    [:##delete_or_backspace :vk_none]
    [:##delete_forward :vk_none]
   ]}

  {:des "[Desktop] Physical equals to backtick"
   :rules [:!apple_internal
    ;; Physical backtick is disabled globally
    ;; Physical equals → backtick
    [{:key :equal_sign :modi {:optional [:any]}} :grave_accent_and_tilde]
    ;; Shift + physical equals → tilde
    [{:key :equal_sign :modi {:mandatory [:shift] :optional [:any]}} :!Sgrave_accent_and_tilde]
   ]}


  {:des "[Desktop] App/Window Switcher Ctrl+N/Ctrl+J exits (must come before global Ctrl+N)"
   :rules [:!apple_internal
    ;; Ctrl+N in app switcher = release Cmd, exit to Normal
    [{:key :n :modi {:mandatory [:right_control]}}
     [["in_modal" 0] ["mode" 0]
      {:shell "osascript -e 'tell app \"System Events\" to key up command' && echo norm > /tmp/karabiner-layer"}] ["mode" 11]]
    ;; Ctrl+N in window switcher = release Cmd, exit to Normal
    [{:key :n :modi {:mandatory [:right_control]}}
     [["in_modal" 0] ["mode" 0]
      {:shell "osascript -e 'tell app \"System Events\" to key up command' && echo norm > /tmp/karabiner-layer"}] ["mode" 12]]
    ;; Ctrl+J in app switcher = release Cmd, exit to Ins
    [{:key :j :modi {:mandatory [:right_control]}}
     [["in_modal" 0] ["mode" 1]
      {:shell "osascript -e 'tell app \"System Events\" to key up command' && echo ins > /tmp/karabiner-layer"}] ["mode" 11]]
    ;; Ctrl+J in window switcher = release Cmd, exit to Ins
    [{:key :j :modi {:mandatory [:right_control]}}
     [["in_modal" 0] ["mode" 1]
      {:shell "osascript -e 'tell app \"System Events\" to key up command' && echo ins > /tmp/karabiner-layer"}] ["mode" 12]]
   ]}

  ;; NOTE: Removed global Ctrl+N→escape rule because it interferes with modal layer exits.
  ;; When exiting Label/Grid mode with Ctrl+N, key repeat would send escape to apps.
  ;; In Normal mode, N alone sends escape. In Ins mode, Ctrl+N isn't needed.

  {:des "[Desktop] Right control+6 to F9 (text-to-speech)"
   :rules [:!apple_internal
    [{:key :6 :modi {:mandatory [:right_control]}} [:f9 ["mode" 1] ["in_modal" 0] {:shell "echo ins > /tmp/karabiner-layer"}]]
   ]}

  {:des "[Desktop] Wispr Flow shortcut"
   :rules [:!apple_internal
    ;; right_control+Y → Ctrl+Alt+Shift+F19 (popo) → exit to Ins
    ;; Global shortcut - works from any mode (nil condition)
    [{:key :y :modi {:mandatory [:right_control]}} [["mode" 1] ["in_modal" 0] ["submode" 0] {:shell "echo ins > /tmp/karabiner-layer"}] nil {:afterup [:!TOSf19]}]
   ]}

  {:des "[Desktop] Ctrl+hk4 (Alt+F22) enters Nav from any layer"
   :rules [:!apple_internal
    ;; Ctrl+hk4 enters Nav - single mode variable handles layer switching
    [:!Of22 [["mode" 2] ["in_modal" 1] [:layer "n"]]]
   ]}

  {:des "[Desktop] Layer N (Nav) - N from Normal = escape, Ctrl+hk4 enters from any layer"
   :rules [:!apple_internal
    ;; N in Normal = escape (stays in Normal)
    [:n :escape ["mode" 0]]
    ;; Entry via Ctrl+hk4 is handled separately
    [:right_control :right_control ["mode" 2] {:alone [["in_modal" 0] ["mode" 0] [:layer "norm"]]}]
    [{:key :j :modi {:mandatory [:control]}} [["in_modal" 0] ["mode" 1] [:layer "ins"]] ["mode" 2]]
    ;; App launching
    [:h [[:open-norm "iTerm"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:j [[:open-norm "Visual Studio Code"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:k [[:open-norm "Karabiner-EventViewer"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    ;; Chrome profiles
    [:n [[:chrome-profile "personal"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:m [[:chrome-profile "work"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:l [[:open-norm "Signal"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:!Of1 [[:open-norm "Messages"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]  ;; Fn+L
    [{:key :l :modi {:mandatory [:right_control]}} [[:open-norm "WhatsApp"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:o [[:open-norm "Obsidian"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:y [:!Cspacebar ["in_modal" 0] ["mode" 1] [:layer "ins"]] ["mode" 2]]  ;; Spotlight → Ins mode
    ;; Finder
    [:period [[:open-norm "Finder"] ["in_modal" 0] ["mode" 0]] ["mode" 2]]
    [:!Of7 [{:shell "open -a 'Finder' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"g\" using {command down, shift down}' && echo norm > /tmp/karabiner-layer"} ["in_modal" 0] ["mode" 0]] ["mode" 2]]  ;; Fn+Period: Go to Folder
    [{:key :period :modi {:mandatory [:right_control]}} [{:shell "open -a 'Finder' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"g\" using {command down, shift down}' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"v\" using command down' -e 'tell app \"System Events\" to key code 36' && echo norm > /tmp/karabiner-layer"} ["in_modal" 0] ["mode" 0]] ["mode" 2]]  ;; Ctrl+Period: Go to Folder + Paste
    ;; Enter = Cmd+Enter (exits to Ins)
    [:return_or_enter [:!Creturn_or_enter ["in_modal" 0] ["mode" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["mode" 2]]
   ]}

  {:des "[Desktop] Label Mode 🐭 (M from Normal, Ctrl+M from Ins) - Homerow"
   :rules [:!apple_internal
    ;; === ENTRY ===
    ;; M from Normal: enter Label mode, trigger Homerow
    [:m [["mode" 13] ["return_to_layer" 0] ["in_modal" 1] :!COSo {:shell "echo label > /tmp/karabiner-layer"}] ["mode" 0]]
    ;; Ctrl+M from Ins: enter Label mode, trigger Homerow
    [{:key :m :modi {:mandatory [:right_control]}} [["mode" 13] ["return_to_layer" 1] ["in_modal" 1] :!COSo {:shell "echo label > /tmp/karabiner-layer"}] ["mode" 1]]

    ;; === EXIT (return to origin) ===
    ;; Uses rule ordering: return_to_layer=1 rules first (exit to Ins), then fallback (exit to Normal)

    ;; Cancel: right_control exits and dismisses Homerow (sends escape to Homerow app only)
    [:right_control [:vk_none ["return_to_layer" 0] ["in_modal" 0] ["mode" 1] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo ins > /tmp/karabiner-layer"}] ["return_to_layer" 1]]
    [:right_control [:vk_none ["return_to_layer" 0] ["in_modal" 0] ["mode" 0] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo norm > /tmp/karabiner-layer"}] ["mode" 13]]
    ;; Ctrl+N and Ctrl+J also exit
    [{:key :n :modi {:mandatory [:right_control]}} [:vk_none ["return_to_layer" 0] ["in_modal" 0] ["mode" 1] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo ins > /tmp/karabiner-layer"}] ["return_to_layer" 1]]
    [{:key :n :modi {:mandatory [:right_control]}} [:vk_none ["return_to_layer" 0] ["in_modal" 0] ["mode" 0] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo norm > /tmp/karabiner-layer"}] ["mode" 13]]
    [{:key :j :modi {:mandatory [:right_control]}} [:vk_none ["return_to_layer" 0] ["in_modal" 0] ["mode" 1] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo ins > /tmp/karabiner-layer"}] ["return_to_layer" 1]]
