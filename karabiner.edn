   ]}

  {:des "[Laptop] Exchange numbers and symbols"
   :rules [:apple_internal
    [{:key :1 :modi {:optional [:caps_lock]}} :!S1]
    [{:key :2 :modi {:optional [:caps_lock]}} :!S2]
    [{:key :3 :modi {:optional [:caps_lock]}} :!S3]
    [{:key :4 :modi {:optional [:caps_lock]}} :!S4]
    [{:key :5 :modi {:optional [:caps_lock]}} :!S5]
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0]
    [{:key :1 :modi {:mandatory [:shift] :optional [:caps_lock]}} :1]
    [{:key :2 :modi {:mandatory [:shift] :optional [:caps_lock]}} :2]
    [{:key :3 :modi {:mandatory [:shift] :optional [:caps_lock]}} :3]
    [{:key :4 :modi {:mandatory [:shift] :optional [:caps_lock]}} :4]
    [{:key :5 :modi {:mandatory [:shift] :optional [:caps_lock]}} :5]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9]
