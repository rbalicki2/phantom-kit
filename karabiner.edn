    [:comma [:!Sc ["submode" 0]] ["submode" 1]]
    [:period [:!Sx ["submode" 0]] ["submode" 1]]
    [:slash [:!Sz ["submode" 0]] ["submode" 1]]
    ;; Numbers are handled in global section (before number swap rules)
   ]}

  {:des "[Desktop] Shift oneshot (Fn+Space then letter = Shift+letter)"
   :rules [:!apple_internal
    ;; Top row
    [:y [:!Sy ["submode" 0]] ["submode" 2]]
    [:u [:!Su ["submode" 0]] ["submode" 2]]
    [:i [:!Si ["submode" 0]] ["submode" 2]]
    [:o [:!So ["submode" 0]] ["submode" 2]]
    [:p [:!Sp ["submode" 0]] ["submode" 2]]
    ;; Home row
    [:h [:!Sh ["submode" 0]] ["submode" 2]]
    [:j [:!Sj ["submode" 0]] ["submode" 2]]
    [:k [:!Sk ["submode" 0]] ["submode" 2]]
    [:l [:!Sl ["submode" 0]] ["submode" 2]]
    [:semicolon [:!Ssemicolon ["submode" 0]] ["submode" 2]]
    ;; Bottom row
    [:n [:!Sn ["submode" 0]] ["submode" 2]]
    [:m [:!Sm ["submode" 0]] ["submode" 2]]
    [:comma [:!Scomma ["submode" 0]] ["submode" 2]]
    [:period [:!Speriod ["submode" 0]] ["submode" 2]]
    [:slash [:!Sslash ["submode" 0]] ["submode" 2]]
   ]}

  {:des "[Desktop] Function+key = Mirror (Fn sends F-keys via Kinesis hardware)"
   :rules [:!apple_internal
    ;; Fn+Quote → enter shift_mirror_oneshot mode (for uppercase mirrored letters)
    [:!Of3 [["submode" 1]] ["mode" 1]]
    ;; Fn+letter in shift_mirror_oneshot → uppercase mirrored letter (must be before regular Fn+letter rules)
    [:f15 [:!St ["submode" 0]] ["submode" 1]]  ;; Fn+Y → T
    [:f16 [:!Sr ["submode" 0]] ["submode" 1]]  ;; Fn+U → R
    [:f17 [:!Se ["submode" 0]] ["submode" 1]]  ;; Fn+I → E
    [:f18 [:!Sw ["submode" 0]] ["submode" 1]]  ;; Fn+O → W
    [:f19 [:!Sq ["submode" 0]] ["submode" 1]]  ;; Fn+P → Q
    [:f22 [:!Sg ["submode" 0]] ["submode" 1]]  ;; Fn+H → G
    [:f23 [:!Sf ["submode" 0]] ["submode" 1]]  ;; Fn+J → F
    [:f24 [:!Sd ["submode" 0]] ["submode" 1]]  ;; Fn+K → D
    [:!Of1 [:!Ss ["submode" 0]] ["submode" 1]]  ;; Fn+L → S
    [:!Of2 [:!Sa ["submode" 0]] ["submode" 1]]  ;; Fn+; → A
    [:!Of4 [:!Sb ["submode" 0]] ["submode" 1]]  ;; Fn+N → B
    [:!Of5 [:!Sv ["submode" 0]] ["submode" 1]]  ;; Fn+M → V
    [:!Of6 [:!Sc ["submode" 0]] ["submode" 1]]  ;; Fn+, → C
    [:!Of7 [:!Sx ["submode" 0]] ["submode" 1]]  ;; Fn+. → X
    [:!Of8 [:!Sz ["submode" 0]] ["submode" 1]]  ;; Fn+/ → Z
    ;; Fn+symbols in shift_mirror_oneshot
    [:f12 [:!Sequal_sign ["submode" 0]] ["submode" 1]]  ;; Fn+hyphen (F12) → +
    [:!Of9 [:backslash ["submode" 0]] ["submode" 1]]  ;; Fn+Up → \
    [:!Of10 [:grave_accent_and_tilde ["submode" 0]] ["submode" 1]]  ;; Fn+Down → `
    [:!Of11 [:!Squote ["submode" 0]] ["submode" 1]]  ;; Fn+[ → "
    [:!Of12 [:!Sgrave_accent_and_tilde ["submode" 0]] ["submode" 1]]  ;; Fn+] → ~
    ;; Fn+numbers in shift_mirror_oneshot → mirrored digit (Kinesis Fn+N sends F(N+1))
    [:f7 [:5 ["submode" 0]] ["submode" 1]]  ;; Fn+6 (F7) → 5
    [:f8 [:4 ["submode" 0]] ["submode" 1]]  ;; Fn+7 (F8) → 4
    [:f9 [:3 ["submode" 0]] ["submode" 1]]  ;; Fn+8 (F9) → 3
    [:f10 [:2 ["submode" 0]] ["submode" 1]]  ;; Fn+9 (F10) → 2
    [:f11 [:1 ["submode" 0]] ["submode" 1]]  ;; Fn+0 (F11) → 1
    ;; Top row: Fn+Y/U/I/O/P → t/r/e/w/q
    [:f15 :t ["mode" 1]]  ;; Fn+Y
    [:f16 :r ["mode" 1]]  ;; Fn+U
    [:f17 :e ["mode" 1]]  ;; Fn+I
    [:f18 :w ["mode" 1]]  ;; Fn+O
    [:f19 :q ["mode" 1]]  ;; Fn+P
    ;; Middle row: Fn+H/J/K/L/; → g/f/d/s/a
    [:f22 :g ["mode" 1]]  ;; Fn+H
    [:f23 :f ["mode" 1]]  ;; Fn+J
    [:f24 :d ["mode" 1]]  ;; Fn+K
    [:!Of1 :s ["mode" 1]]  ;; Fn+L
    [:!Of2 :a ["mode" 1]]  ;; Fn+;
    ;; Bottom row: Fn+N/M/,/./slash → b/v/c/x/z
    [:!Of4 :b ["mode" 1]]  ;; Fn+N
    [:!Of5 :v ["mode" 1]]  ;; Fn+M
    [:!Of6 :c ["mode" 1]]  ;; Fn+,
    [:!Of7 :x ["mode" 1]]  ;; Fn+.
    [:!Of8 :z ["mode" 1]]  ;; Fn+/
    ;; Fn+numbers → mirrored symbols (Kinesis Fn+N sends F(N+1))
    [:f7 :!S5 ["mode" 1]]  ;; Fn+6 (F7) → %
    [:f8 :!S4 ["mode" 1]]  ;; Fn+7 (F8) → $
    [:f9 :!S3 ["mode" 1]]  ;; Fn+8 (F9) → #
    [:f10 :!S2 ["mode" 1]]  ;; Fn+9 (F10) → @
    [:f11 :!S1 ["mode" 1]]  ;; Fn+0 (F11) → !
    ;; Symbols
    [:f20 :!Stab ["mode" 1]]  ;; Fn+backslash (F20) → Shift+Tab
    ;; F12 (Fn+hyphen) passes through naturally
    [:!Of9 :!Sopen_bracket ["mode" 1]]  ;; Fn+Up → {
    [:!Of10 :!Sclose_bracket ["mode" 1]]  ;; Fn+Down → }
    ;; Fn+[ unmapped (passes through as backspace via base [ = backspace rule)
    [:!Of12 :!Sgrave_accent_and_tilde ["mode" 1]]  ;; Fn+] → ~ (tilde)
   ]}

  {:des "[Desktop] Normal Layer (default state, layer selector)"
   :rules [:!apple_internal
    ;; On boot, mode defaults to 0 (Normal). If stuck in unexpected state, use panic button (Fn+hk3).
    ;; Each layer has its own right_control exit rule, so no fallback needed here.
   ]}

  {:des "[Desktop] Normal Layer - Disable unmapped keys"
   :rules [:!apple_internal
    ;; In Normal mode, only layer selector keys should work
    ;; Disable all other letter keys to prevent accidental typing (## catches shift variants)
    ;; Active keys: j (Ins), n (Nav), m (Mouse), l (H), u (Term), h (app-specific), comma (Comma layer)
    [:##a :vk_none ["mode" 0]]
    [:##b :vk_none ["mode" 0]]
    [:##c :vk_none ["mode" 0]]
    [:##d :vk_none ["mode" 0]]
    [:##e :vk_none ["mode" 0]]
    [:##f :vk_none ["mode" 0]]
    [:##g :vk_none ["mode" 0]]
    [:##k :vk_none ["mode" 0]]
    [:##o :vk_none ["mode" 0]]
    [:##p :vk_none ["mode" 0]]
    [:##q :vk_none ["mode" 0]]
    [:##r :vk_none ["mode" 0]]
    [:##s :vk_none ["mode" 0]]
    [:##t :vk_none ["mode" 0]]
    [:##v :vk_none ["mode" 0]]
    [:##w :vk_none ["mode" 0]]
    [:##x :vk_none ["mode" 0]]
    [:##y :vk_none ["mode" 0]]
    [:##z :vk_none ["mode" 0]]
    ;; Disable brackets
    [:##open_bracket :vk_none ["mode" 0]]
    [:##close_bracket :vk_none ["mode" 0]]
    ;; Also disable period, semicolon, slash (not layer selectors) - ## catches shift variants
    [:##period :vk_none ["mode" 0]]
    [:##semicolon :vk_none ["mode" 0]]
    [:##slash :vk_none ["mode" 0]]
    ;; Disable numbers 6-0, backslash, hyphen, quote (with any modifiers)
    [:##quote :vk_none ["mode" 0]]
    [:##6 :vk_none ["mode" 0]]
    [:##7 :vk_none ["mode" 0]]
    [:##8 :vk_none ["mode" 0]]
    [:##9 :vk_none ["mode" 0]]
    [:##0 :vk_none ["mode" 0]]
    [:##backslash :vk_none ["mode" 0]]
    [:##hyphen :vk_none ["mode" 0]]
    ;; Shift+layer-entry-keys disabled (bare key enters layer, shift should do nothing)
    ;; Use explicit {:modi {:mandatory [:shift]}} to match EITHER left or right shift
    [{:key :u :modi {:mandatory [:shift]}} :vk_none ["mode" 0]]
    [{:key :h :modi {:mandatory [:shift]}} :vk_none ["mode" 0]]
    [{:key :j :modi {:mandatory [:shift]}} :vk_none ["mode" 0]]
    [{:key :l :modi {:mandatory [:shift]}} :vk_none ["mode" 0]]
    [{:key :n :modi {:mandatory [:shift]}} :vk_none ["mode" 0]]
    [{:key :m :modi {:mandatory [:shift]}} :vk_none ["mode" 0]]
    [{:key :comma :modi {:mandatory [:shift]}} :vk_none ["mode" 0]]
    [:##spacebar :vk_none ["mode" 0]]
    [:page_down :vk_none ["mode" 0]]
    [:page_up :vk_none ["mode" 0]]
   ]}

  {:des "[Desktop] Block unmapped keys in all working layers (in_any_layer=1)"
   :rules [:!apple_internal
    ;; When in a layer (Nav, Chrome, Mouse, etc.), block all letter keys
    ;; Specific layer mappings come earlier in config and take precedence
    [:##a :vk_none ["in_modal" 1]]
    [:##b :vk_none ["in_modal" 1]]
    [:##c :vk_none ["in_modal" 1]]
    [:##d :vk_none ["in_modal" 1]]
    [:##e :vk_none ["in_modal" 1]]
    [:##f :vk_none ["in_modal" 1]]
