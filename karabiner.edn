    [:u :!Copen_bracket ["mode" 10]]   ;; Back
    [:i :!Cclose_bracket ["mode" 10]]  ;; Forward
    ;; Tabs (M/Comma = prev/next, Y = close, Fn+Y = reopen) - STAY in layer
    [:m :!TStab ["mode" 10]]   ;; Prev tab
    [:comma :!Ttab ["mode" 10]]  ;; Next tab
    [:!Of5 :!TSpage_up ["mode" 10]]   ;; Fn+M = Move tab left
    [:!Of6 :!TSpage_down ["mode" 10]]  ;; Fn+, = Move tab right
