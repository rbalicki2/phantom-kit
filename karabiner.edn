  {:des "[Layer 28] Grid Mode 🐭🔲 - warpd"
   :rules [:!apple_internal
    ;; (Entry from Normal is in Layer 0 section)

    ;; === EXIT (no click) ===
    ;; All exits: kill warpd, set mode to Normal
    [:right_control [:vk_none ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "pkill warpd; echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 28]]
    [{:key :n :modi {:mandatory [:right_control]}} [:vk_none ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "pkill warpd; echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 28]]
    [{:key :j :modi {:mandatory [:right_control]}} [:vk_none ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "pkill warpd; echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 28]]
    [:up_arrow [:vk_none ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "pkill warpd; echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 28]]

    ;; === CLICK ACTIONS ===
    ;; Kill warpd first (mouse stays where warpd put it), then trigger our own click
    ;; Space = left click
    [:spacebar [:vk_none ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "pkill warpd; /opt/homebrew/bin/hs -c 'clickLeft()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 28]]

    ;; Fn+Space = cmd+click
    [:!Of18 [:vk_none ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "pkill warpd; /opt/homebrew/bin/hs -c 'clickCmd()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 28]]

    ;; Shift+Space = shift+click
    [{:key :spacebar :modi {:mandatory [:shift]}} [:vk_none ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "pkill warpd; /opt/homebrew/bin/hs -c 'clickShift()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 28]]

    ;; Enter = right-click (ctrl+click)
