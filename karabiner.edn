    [:y :y ["dsk_layer" 13]]
    [:u :u ["dsk_layer" 13]]
    [:i :i ["dsk_layer" 13]]
    [:o :o ["dsk_layer" 13]]
    [:p :p ["dsk_layer" 13]]
    [:h :h ["dsk_layer" 13]]
    [:j :j ["dsk_layer" 13]]
    [:k :k ["dsk_layer" 13]]
    [:l :l ["dsk_layer" 13]]
    [:n :n ["dsk_layer" 13]]
    [:m :m ["dsk_layer" 13]]
    [:comma :comma ["dsk_layer" 13]]
    [:period :period ["dsk_layer" 13]]
    [:semicolon :semicolon ["dsk_layer" 13]]
    [:slash :slash ["dsk_layer" 13]]
   ]}

  ;; =====================================================================
