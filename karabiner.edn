  {:des "[Layer 13] Label Mode 🐭 - Homerow"
   :rules [:!apple_internal
    ;; === ENTRY from Ins (Ctrl+M) ===
    ;; (M from Normal entry is in Layer 0 section)
    [{:key :m :modi {:mandatory [:right_control]}} [["dsk_layer" 13] ["dsk_return_to_layer" 1] ["dsk_in_modal_layer" 1] :!COSo {:shell "echo label > /tmp/karabiner-layer"}] ["dsk_layer" 1]]

    ;; === EXIT (return to origin) ===
    ;; Uses rule ordering: return_to_layer=1 rules first (exit to Ins), then fallback (exit to Normal)

    ;; Cancel: right_control exits and dismisses Homerow (sends escape to Homerow app only)
    [:right_control [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [:right_control [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]
    ;; Ctrl+N and Ctrl+J also exit
    [{:key :n :modi {:mandatory [:right_control]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [{:key :n :modi {:mandatory [:right_control]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]
    [{:key :j :modi {:mandatory [:right_control]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [{:key :j :modi {:mandatory [:right_control]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'dismissHomerow()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

    ;; Up = Hover exit (move mouse without clicking)
    [:up_arrow [["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'hoverAndEnter()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [:up_arrow [["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'hoverAndEnter()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

    ;; Space = Click (left click via Homerow)
    [:spacebar [:return_or_enter ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [:spacebar [:return_or_enter ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

    ;; Fn+Space = Cmd+click (via Hammerspoon)
    [:!Of18 [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'labelCmdClick()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [:!Of18 [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'labelCmdClick()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

    ;; Shift+Space = Shift+click (via Hammerspoon)
    [{:key :spacebar :modi {:mandatory [:shift]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'labelShiftClick()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [{:key :spacebar :modi {:mandatory [:shift]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'labelShiftClick()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

    ;; Shift+Enter = Cmd+Shift+click (via Hammerspoon)
    [{:key :return_or_enter :modi {:mandatory [:shift]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'labelCmdShiftClick()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [{:key :return_or_enter :modi {:mandatory [:shift]}} [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'labelCmdShiftClick()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

    ;; Enter = Right-click (ctrl+click via Hammerspoon)
    [:return_or_enter [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'labelRightClick()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [:return_or_enter [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'labelRightClick()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

