    [:!Of17 [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 1] {:shell "/opt/homebrew/bin/hs -c 'labelDoubleClick()' && echo ins > /tmp/karabiner-layer"}] ["dsk_return_to_layer" 1]]
    [:!Of17 [:vk_none ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_layer" 0] {:shell "/opt/homebrew/bin/hs -c 'labelDoubleClick()' && echo norm > /tmp/karabiner-layer"}] ["dsk_layer" 13]]

    ;; === PASSTHROUGH ===
