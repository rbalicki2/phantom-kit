    [:!Of17 :!Sreturn_or_enter ["mode" 1]]
    ;; [ = backspace, ] = delete in Ins mode
    [:open_bracket :delete_or_backspace ["mode" 1]]
    [:close_bracket :delete_forward ["mode" 1]]
   ]}

