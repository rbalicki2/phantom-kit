    [:j [{:shell "/opt/homebrew/bin/hs -c 'scrollStart(-30)'"}] ["mode" 10] {:afterup [{:shell "/opt/homebrew/bin/hs -c 'scrollStop()'"}]}]  ;; J = Scroll down (hold to repeat)
