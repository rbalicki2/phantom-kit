    [{:key :period :modi {:mandatory [:right_control]}} [{:shell "open -a 'Finder' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"g\" using {command down, shift down}' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"v\" using command down' -e 'tell app \"System Events\" to key code 36' && echo norm > /tmp/karabiner-layer"} ["dsk_in_modal_layer" 0] ["dsk_layer" 0]] ["dsk_layer" 2]]  ;; Ctrl+Period: Go to Folder + Paste
