  {:des "[Desktop] Disable LHS keys and arrows"
   :rules [:!apple_internal
    [:##grave_accent_and_tilde :vk_none]
    [:##non_us_backslash :vk_none]
    [:##left_arrow :vk_none]
    [:##right_arrow :vk_none]
    [:##q :vk_none]
    [:##w :vk_none]
    [:##e :vk_none]
    [:##r :vk_none]
    [:##t :vk_none]
