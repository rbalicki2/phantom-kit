;; Goku config - 1:1 conversion of karabiner.json
;; Run `goku` after editing to regenerate karabiner.json
;;
;; Modifier key legend:
;;   ! = mandatory modifier
;;   # = optional modifier
;;   C = left_command, Q = right_command
;;   T = left_control (NOT right_control - use full form for that)
;;   O = left_option,  E = right_option
;;   S = left_shift,   R = right_shift
;;   W = fn
;;
;; ## = :optional ["any"]
;; For right_control, use: {:key :x :modi {:mandatory [:right_control]}}

{
 :profiles {
  :None {
   :default false
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
  :Default {
   :default false
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
  :Desktop {
   :default true
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
 }

 :devices {
  :trackball [{:vendor_id 10730 :product_id 258 :is_pointing_device true}]
  :logitech [{:vendor_id 1133 :product_id 45921 :is_keyboard true :is_pointing_device true}]
 }

 :applications {
  :iTerm ["com.googlecode.iterm2"]
  :Chrome ["com.google.Chrome"]
  :VSCode ["com.microsoft.VSCode"]
 }

 :simlayers {
 }

 ;; Templates reduce repetition in shell commands
 ;; Usage: [:layer "norm"] expands to {:shell "echo norm > /tmp/karabiner-layer"}
 :templates {
  ;; Layer indicator (writes to /tmp/karabiner-layer for SwiftBar/Hammerspoon)
  :layer "echo %s > /tmp/karabiner-layer"
  ;; App launching
  :open "open -a '%s'"
  :open-norm "open -a '%s' && echo norm > /tmp/karabiner-layer"
  ;; Git/terminal typing (Term layer)
  :type "osascript -e 'tell app \"System Events\" to keystroke \"%s\"'"
  :type-norm "osascript -e 'tell app \"System Events\" to keystroke \"%s\"' && echo norm > /tmp/karabiner-layer"
  :type-enter "osascript -e 'tell app \"System Events\" to keystroke \"%s\"' -e 'tell app \"System Events\" to key code 36'"
  :type-enter-norm "osascript -e 'tell app \"System Events\" to keystroke \"%s\"' -e 'tell app \"System Events\" to key code 36' && echo norm > /tmp/karabiner-layer"
  ;; Chrome tab by index
  :chrome-tab "osascript -e 'tell application \"Google Chrome\" to set active tab index of front window to %s' && echo norm > /tmp/karabiner-layer"
  ;; Chrome profile switching
  :chrome-profile "/Users/rbalicki/code/voicemode/chrome-tab.sh %s && echo norm > /tmp/karabiner-layer"
  ;; iTerm tab selection
  :iterm-tab "osascript -e 'tell application \"iTerm\" to tell current window to select tab %s' && echo norm > /tmp/karabiner-layer"
  ;; System Events helpers
  :key-down "osascript -e 'tell application \"System Events\" to key down %s'"
  :key-up "osascript -e 'tell application \"System Events\" to key up %s'"
 }

 :main [

  ;; =====================================================================
  ;; ALL PROFILES - Common rules (no profile condition)
  ;; =====================================================================

  {:des "Caps lock to control/escape"
   :rules [
    [:##caps_lock :left_control nil {:alone :escape}]
   ]}


  {:des "RHS mode number handling (must come before number swap)"
   :rules [
    ;; Disable LHS numbers 1-5
    [:1 :vk_none ["layer_rhs" 1]]
    [:2 :vk_none ["layer_rhs" 1]]
    [:3 :vk_none ["layer_rhs" 1]]
    [:4 :vk_none ["layer_rhs" 1]]
    [:5 :vk_none ["layer_rhs" 1]]
    ;; Mirror RHS numbers to LHS (f held): 6→5, 7→4, 8→3, 9→2, 0→1
    ;; Bare → shifted (symbol), Shift → bare (digit) to match swap
    [:6 :!S5 ["layer_mirror" 1]]
    [:7 :!S4 ["layer_mirror" 1]]
    [:8 :!S3 ["layer_mirror" 1]]
    [:9 :!S2 ["layer_mirror" 1]]
    [:0 :!S1 ["layer_mirror" 1]]
    ;; Shifted versions → bare digit
    [{:key :6 :modi {:mandatory [:shift]}} :5 ["layer_mirror" 1]]
    [{:key :7 :modi {:mandatory [:shift]}} :4 ["layer_mirror" 1]]
    [{:key :8 :modi {:mandatory [:shift]}} :3 ["layer_mirror" 1]]
    [{:key :9 :modi {:mandatory [:shift]}} :2 ["layer_mirror" 1]]
    [{:key :0 :modi {:mandatory [:shift]}} :1 ["layer_mirror" 1]]
   ]}

  {:des "Mirror mode numbers (must come before number swap)"
   :rules [
    ;; These rules match first when mirror_mode is active, preventing number swap
    [:6 :!S5 ["mirror_mode" 1]]
    [:7 :!S4 ["mirror_mode" 1]]
    [:8 :!S3 ["mirror_mode" 1]]
    [:9 :!S2 ["mirror_mode" 1]]
    [:0 :!S1 ["mirror_mode" 1]]
    [{:key :6 :modi {:mandatory [:shift]}} :5 ["mirror_mode" 1]]
    [{:key :7 :modi {:mandatory [:shift]}} :4 ["mirror_mode" 1]]
    [{:key :8 :modi {:mandatory [:shift]}} :3 ["mirror_mode" 1]]
    [{:key :9 :modi {:mandatory [:shift]}} :2 ["mirror_mode" 1]]
    [{:key :0 :modi {:mandatory [:shift]}} :1 ["mirror_mode" 1]]
   ]}

  {:des "Exchange numbers and symbols"
   :rules [
    [{:key :1 :modi {:optional [:caps_lock]}} :!S1]
    [{:key :2 :modi {:optional [:caps_lock]}} :!S2]
    [{:key :3 :modi {:optional [:caps_lock]}} :!S3]
    [{:key :4 :modi {:optional [:caps_lock]}} :!S4]
    [{:key :5 :modi {:optional [:caps_lock]}} :!S5]
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6 ["layer_normal" 0]]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7 ["layer_normal" 0]]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8 ["layer_normal" 0]]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9 ["layer_normal" 0]]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0 ["layer_normal" 0]]
    [{:key :1 :modi {:mandatory [:shift] :optional [:caps_lock]}} :1]
    [{:key :2 :modi {:mandatory [:shift] :optional [:caps_lock]}} :2]
    [{:key :3 :modi {:mandatory [:shift] :optional [:caps_lock]}} :3]
    [{:key :4 :modi {:mandatory [:shift] :optional [:caps_lock]}} :4]
    [{:key :5 :modi {:mandatory [:shift] :optional [:caps_lock]}} :5]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6 ["layer_normal" 0]]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7 ["layer_normal" 0]]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8 ["layer_normal" 0]]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9 ["layer_normal" 0]]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0 ["layer_normal" 0]]
   ]}

  {:des "Brackets to command+bracket (only in working layers)"
   :rules [
    [{:key :open_bracket :modi {:optional [:caps_lock]}} :!Copen_bracket ["in_any_layer" 1]]
    [{:key :close_bracket :modi {:optional [:caps_lock]}} :!Cclose_bracket ["in_any_layer" 1]]
    ;; Cmd+bracket → bare bracket (only in working layers, blocked in Normal)
    [{:key :open_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :open_bracket ["in_any_layer" 1]]
    [{:key :close_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :close_bracket ["in_any_layer" 1]]
    [{:key :close_bracket :modi {:mandatory [:shift] :optional [:caps_lock]}} :open_bracket ["in_any_layer" 1]]
   ]}

  {:des "Swap backslash and pipe"
   :rules [
    [:!Sbackslash :backslash ["layer_normal" 0]]
    [{:key :backslash :modi {:mandatory []}} :!Sbackslash ["layer_normal" 0]]
   ]}

  {:des "Left shift to open paren when alone"
   :rules [
    [:##left_shift :left_shift ["in_any_layer" 1] {:alone :!S9}]
   ]}

  {:des "Right shift to close paren when alone"
   :rules [
    [:##right_shift :right_shift ["in_any_layer" 1] {:alone :!S0}]
   ]}

  ;; =====================================================================
  ;; DESKTOP ONLY
  ;; =====================================================================

  {:des "[Desktop] Disable LHS keys and arrows"
   :rules [:Desktop
    [:##grave_accent_and_tilde :vk_none]  ;; physical backtick
    [:##non_us_backslash :vk_none]  ;; § key
    [:##left_arrow :vk_none]
    [:##right_arrow :vk_none]
    [:##q :vk_none]
    [:##w :vk_none]
    [:##e :vk_none]
    [:##r :vk_none]
    [:##t :vk_none]
    [:##a :vk_none]
    [:##s :vk_none]
    [:##d :vk_none]
    [:##f :vk_none]
    [:##g :vk_none]
    [:##z :vk_none]
    [:##x :vk_none]
    [:##c :vk_none]
    [:##v :vk_none]
    [:##b :vk_none]
   ]}

  {:des "[Desktop] Page down/up to click/right click"
   :rules [:Desktop
    ;; Exclude when in Cmd sub-layer (it handles Cmd+click)
    [:##page_down :button1 ["layer_l_cmd" 0]]
    [:##page_up :button2 ["layer_l_cmd" 0]]
   ]}

  {:des "[Desktop] RHS Flag (right_control+7/8 to enter/exit) - disable LHS keys"
   :rules [:Desktop
    ;; right_control+7 enters RHS mode
    [{:key :7 :modi {:mandatory [:right_control]}} [["layer_rhs" 1] {:shell "echo 1 > /tmp/karabiner-rhs"}] ["layer_rhs" 0]]
    ;; right_control+8 exits RHS mode
    [{:key :8 :modi {:mandatory [:right_control]}} [["layer_rhs" 0] {:shell ": > /tmp/karabiner-rhs"}] ["layer_rhs" 1]]
    ;; Disable all LHS keys when RHS flag is on (except f which is mirror modifier)
    ;; Note: numbers 1-5 disabled earlier (before number swap rule)
    [:grave_accent_and_tilde :vk_none ["layer_rhs" 1]]  ;; physical backtick
    [{:key :grave_accent_and_tilde :modi {:mandatory [:shift]}} :vk_none ["layer_rhs" 1]]  ;; shift+physical backtick
    [:q :vk_none ["layer_rhs" 1]]
    [:w :vk_none ["layer_rhs" 1]]
    [:e :vk_none ["layer_rhs" 1]]
    [:r :vk_none ["layer_rhs" 1]]
    [:t :vk_none ["layer_rhs" 1]]
    [:a :vk_none ["layer_rhs" 1]]
    [:s :vk_none ["layer_rhs" 1]]
    [:d :vk_none ["layer_rhs" 1]]
    [:g :vk_none ["layer_rhs" 1]]
    [:z :vk_none ["layer_rhs" 1]]
    [:x :vk_none ["layer_rhs" 1]]
    [:c :vk_none ["layer_rhs" 1]]
    [:v :vk_none ["layer_rhs" 1]]
    [:b :vk_none ["layer_rhs" 1]]
    ;; f held in RHS mode enables mirroring
    [:f ["layer_mirror" 1] ["layer_rhs" 1] {:afterup ["layer_mirror" 0]}]
    ;; Mirror mappings (f held): RHS key → LHS equivalent
    ;; Top row: y→t, u→r, i→e, o→w, p→q
    [:y :t ["layer_mirror" 1]]
    [:u :r ["layer_mirror" 1]]
    [:i :e ["layer_mirror" 1]]
    [:o :w ["layer_mirror" 1]]
    [:p :q ["layer_mirror" 1]]
    ;; Home row: h→g, j→f, k→d, l→s, ;→a
    [:h :g ["layer_mirror" 1]]
    [:j :f ["layer_mirror" 1]]
    [:k :d ["layer_mirror" 1]]
    [:l :s ["layer_mirror" 1]]
    [:semicolon :a ["layer_mirror" 1]]
    ;; Bottom row: n→b, m→v, ,→c, .→x, /→z
    [:n :b ["layer_mirror" 1]]
    [:m :v ["layer_mirror" 1]]
    [:comma :c ["layer_mirror" 1]]
    [:period :x ["layer_mirror" 1]]
    [:slash :z ["layer_mirror" 1]]
    ;; Note: number mirrors moved to ALL PROFILES section (before number swap)
    ;; Shifted versions (for letters, shift passes through automatically)
    [{:key :y :modi {:mandatory [:shift]}} :!St ["layer_mirror" 1]]
    [{:key :u :modi {:mandatory [:shift]}} :!Sr ["layer_mirror" 1]]
    [{:key :i :modi {:mandatory [:shift]}} :!Se ["layer_mirror" 1]]
    [{:key :o :modi {:mandatory [:shift]}} :!Sw ["layer_mirror" 1]]
    [{:key :p :modi {:mandatory [:shift]}} :!Sq ["layer_mirror" 1]]
    [{:key :h :modi {:mandatory [:shift]}} :!Sg ["layer_mirror" 1]]
    [{:key :j :modi {:mandatory [:shift]}} :!Sf ["layer_mirror" 1]]
    [{:key :k :modi {:mandatory [:shift]}} :!Sd ["layer_mirror" 1]]
    [{:key :l :modi {:mandatory [:shift]}} :!Ss ["layer_mirror" 1]]
    [{:key :semicolon :modi {:mandatory [:shift]}} :!Sa ["layer_mirror" 1]]
    [{:key :n :modi {:mandatory [:shift]}} :!Sb ["layer_mirror" 1]]
    [{:key :m :modi {:mandatory [:shift]}} :!Sv ["layer_mirror" 1]]
    [{:key :comma :modi {:mandatory [:shift]}} :!Sc ["layer_mirror" 1]]
    [{:key :period :modi {:mandatory [:shift]}} :!Sx ["layer_mirror" 1]]
    [{:key :slash :modi {:mandatory [:shift]}} :!Sz ["layer_mirror" 1]]
   ]}

  {:des "[Desktop] Right command + brackets to ctrl-tab navigation"
   :rules [:Desktop
    [{:key :open_bracket :modi {:mandatory [:right_command]}} :!TStab]
    [{:key :close_bracket :modi {:mandatory [:right_command]}} :!Ttab]
   ]}

  {:des "[Desktop] Right control + brackets to backspace/delete"
   :rules [:Desktop
    [{:key :open_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_or_backspace :modi []}]
    [{:key :close_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_forward :modi []}]
   ]}

  
  {:des "[Desktop] Right command to close curly/bracket when alone"
   :rules [:Desktop
    [:right_command :right_command nil {:alone :!Sclose_bracket}]
    [{:key :right_command :modi {:mandatory [:shift]}} {:key :right_command :modi [:left_shift]} nil {:alone :close_bracket}]
   ]}

  {:des "[Desktop] Left command to open curly/bracket when alone"
   :rules [:Desktop
    [:left_command :left_command nil {:alone :!Sopen_bracket}]
    [:!Sleft_command {:key :left_command :modi [:left_shift]} nil {:alone :open_bracket}]
   ]}

  {:des "[Desktop] Arrow navigation with right command"
   :rules [:Desktop
    ;; right_command + j = option + left (word left)
    [{:key :j :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:right_option]}]
    ;; right_command + k = option + right (word right)
    [{:key :k :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:right_option]}]
    ;; right_command + m = command + left (line start)
    [{:key :m :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:left_command]}]
    ;; right_command + comma = command + right (line end)
    [{:key :comma :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:left_command]}]
    ;; right_command + up = left
    [{:key :up_arrow :modi {:mandatory [:right_command] :optional [:any]}} :left_arrow]
    ;; right_command + down = right
    [{:key :down_arrow :modi {:mandatory [:right_command] :optional [:any]}} :right_arrow]
   ]}

  {:des "[Desktop] Disable backspace and delete keys"
   :rules [:Desktop
    [:##delete_or_backspace :vk_none]
    [:##delete_forward :vk_none]
   ]}

  {:des "[Desktop] Physical equals to backtick"
   :rules [:Desktop
    ;; Physical backtick is disabled globally
    ;; Physical equals → backtick
    [{:key :equal_sign :modi {:optional [:any]}} :grave_accent_and_tilde]
    ;; Shift + physical equals → tilde
    [{:key :equal_sign :modi {:mandatory [:shift] :optional [:any]}} :!Sgrave_accent_and_tilde]
   ]}

  {:des "[Desktop] Home to enter"
   :rules [:Desktop
    [:home :return_or_enter]
   ]}

  {:des "[Desktop] Right control+6 to F9 (text-to-speech)"
   :rules [:Desktop
    [{:key :6 :modi {:mandatory [:right_control]}} [:f9 ["layer_ins" 1] ["layer_normal" 0] ["in_any_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}]]
   ]}

  {:des "[Desktop] Right control+Y to Shift+F9 (toggle recording)"
   :rules [:Desktop
    [{:key :y :modi {:mandatory [:right_control]}} [:!Sf9 ["layer_ins" 1] ["layer_normal" 0] ["in_any_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}]]
   ]}

  {:des "[Desktop] Layer N (n from Normal to enter)"
   :rules [:Desktop
    ;; Entry/exit
    [:n [["layer_n" 1] ["layer_normal" 0] ["in_any_layer" 1] [:layer "n"]] ["layer_normal" 1]]
    [:escape [["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]] ["layer_n" 1]]
    [:right_control :right_control ["layer_n" 1] {:alone [["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]]}]
    [{:key :j :modi {:mandatory [:control]}} [["layer_n" 0] ["in_any_layer" 0] ["layer_ins" 1] [:layer "ins"]] ["layer_n" 1]]
    ;; Shortcuts
    [:n [:!Cspacebar ["layer_n" 0] ["in_any_layer" 0] ["layer_ins" 1] [:layer "ins"]] ["layer_n" 1]]  ;; Spotlight → Ins mode
    [{:key :h :modi {:mandatory [:right_control]}} :!Cw ["layer_n" 1]]  ;; Close (stays)
    [:return_or_enter [:!Cgrave_accent_and_tilde ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]] ["layer_n" 1]]  ;; Switch windows
    ;; Window management (BTT)
    [:spacebar [:!CTOSg ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]] ["layer_n" 1]]  ;; Maximize
    [:up_arrow [:!CTOSv ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]] ["layer_n" 1]]  ;; Left half
    [:down_arrow [:!CTOSb ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]] ["layer_n" 1]]  ;; Right half
    ;; Chrome profiles
    [:m [[:chrome-profile "personal"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:comma [[:chrome-profile "work"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    ;; Tab switching (stays in layer)
    [:u :!TStab ["layer_n" 1]]
    [:i :!Ttab ["layer_n" 1]]
    ;; App launching
    [:j [[:open-norm "iTerm"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:k [[:open-norm "Visual Studio Code"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:h [[:open-norm "Karabiner-EventViewer"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:l [[:open-norm "Signal"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:o [[:open-norm "Obsidian"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:period [[:open-norm "Finder"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    ;; Finder go-to-folder (complex, no template)
    [{:key :period :modi {:mandatory [:shift]}} [{:shell "open -a 'Finder' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"g\" using {command down, shift down}' && echo norm > /tmp/karabiner-layer"} ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [{:key :period :modi {:mandatory [:right_control]}} [{:shell "open -a 'Finder' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"g\" using {command down, shift down}' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"v\" using command down' -e 'tell app \"System Events\" to key code 36' && echo norm > /tmp/karabiner-layer"} ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    ;; iTerm tabs
    [{:key :n :modi {:mandatory [:shift]}} [[:iterm-tab "1"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [{:key :m :modi {:mandatory [:shift]}} [[:iterm-tab "2"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [{:key :comma :modi {:mandatory [:shift]}} [[:iterm-tab "3"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    ;; Switch layers
    [{:key :h :modi {:mandatory [:shift]}} [{:shell "osascript -e 'tell application \"System Events\" to key down command' -e 'tell application \"System Events\" to keystroke tab' && echo switch > /tmp/karabiner-layer"} ["layer_n" 0] ["layer_appswitcher" 1] ["in_any_layer" 1]] ["layer_n" 1]]
    [{:key :j :modi {:mandatory [:shift]}} [{:shell "osascript -e 'tell application \"System Events\" to key down command' -e 'tell application \"System Events\" to key code 50' && echo winsw > /tmp/karabiner-layer"} ["layer_n" 0] ["layer_windowswitcher" 1] ["in_any_layer" 1]] ["layer_n" 1]]
    ;; Screenshots
    [{:key :p :modi {:mandatory [:right_control]}} [:!CS4 ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]] ["layer_n" 1]]
    [:p [:!CS3 ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]] ["layer_n" 1]]
   ]}

  {:des "[Desktop] Switch Layer - App Switcher (from Nav Shift+H)"
   :rules [:Desktop
    ;; J = Tab (cycle forward in app switcher, Cmd still held)
    [:j [{:shell "osascript -e 'tell application \"System Events\" to keystroke tab'"} ] ["layer_appswitcher" 1]]
    ;; K = Shift+Tab (cycle backward in app switcher)
    [:k [{:shell "osascript -e 'tell application \"System Events\" to keystroke tab using shift down'"} ] ["layer_appswitcher" 1]]
    ;; escape exits to Normal and releases Cmd
    [:escape [{:shell "osascript -e 'tell application \"System Events\" to key up command' && echo norm > /tmp/karabiner-layer"} ["layer_appswitcher" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_appswitcher" 1]]
    ;; enter exits to Normal and releases Cmd
    [:return_or_enter [{:shell "osascript -e 'tell application \"System Events\" to key up command' && echo norm > /tmp/karabiner-layer"} ["layer_appswitcher" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_appswitcher" 1]]
    ;; right_control alone exits to Normal and releases Cmd
    [:right_control :right_control ["layer_appswitcher" 1] {:alone [{:shell "osascript -e 'tell application \"System Events\" to key up command' && echo norm > /tmp/karabiner-layer"} ["layer_appswitcher" 0] ["in_any_layer" 0] ["layer_normal" 1]]}]
    ;; Ctrl+J = global shortcut to Ins layer (releases Cmd)
    [{:key :j :modi {:mandatory [:control]}} [{:shell "osascript -e 'tell application \"System Events\" to key up command' && echo ins > /tmp/karabiner-layer"} ["layer_appswitcher" 0] ["in_any_layer" 0] ["layer_ins" 1]] ["layer_appswitcher" 1]]
   ]}

  {:des "[Desktop] Window Switcher Layer (from Nav Shift+J)"
   :rules [:Desktop
    ;; J = ` (cycle forward in window switcher, Cmd still held)
    [:j [{:shell "osascript -e 'tell application \"System Events\" to key code 50'"} ] ["layer_windowswitcher" 1]]
    ;; K = Shift+` (cycle backward in window switcher)
    [:k [{:shell "osascript -e 'tell application \"System Events\" to key code 50 using shift down'"} ] ["layer_windowswitcher" 1]]
    ;; escape exits to Normal and releases Cmd
