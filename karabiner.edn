;; Goku config - 1:1 conversion of karabiner.json
;; Run `goku` after editing to regenerate karabiner.json
;;
;; Modifier key legend:
;;   ! = mandatory modifier
;;   # = optional modifier
;;   C = left_command, Q = right_command
;;   T = left_control (NOT right_control - use full form for that)
;;   O = left_option,  E = right_option
;;   S = left_shift,   R = right_shift
;;   W = fn
;;
;; ## = :optional ["any"]
;; For right_control, use: {:key :x :modi {:mandatory [:right_control]}}

{
 :profiles {
  :None {
   :default false
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
  :Default {
   :default false
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
  :Desktop {
   :default true
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
 }

 :devices {
  :trackball [{:vendor_id 10730 :product_id 258 :is_pointing_device true}]
  :logitech [{:vendor_id 1133 :product_id 45921 :is_keyboard true :is_pointing_device true}]
 }

 :applications {
  :iTerm ["com.googlecode.iterm2"]
  :Chrome ["com.google.Chrome"]
 }

 :simlayers {
 }

 :main [

  ;; =====================================================================
  ;; ALL PROFILES - Common rules (no profile condition)
  ;; =====================================================================

  {:des "Caps lock to control/escape"
   :rules [
    [:##caps_lock :left_control nil {:alone :escape}]
   ]}

  {:des "Exchange numbers and symbols"
   :rules [
    [{:key :1 :modi {:optional [:caps_lock]}} :!S1]
    [{:key :2 :modi {:optional [:caps_lock]}} :!S2]
    [{:key :3 :modi {:optional [:caps_lock]}} :!S3]
    [{:key :4 :modi {:optional [:caps_lock]}} :!S4]
    [{:key :5 :modi {:optional [:caps_lock]}} :!S5]
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0]
    [{:key :1 :modi {:mandatory [:shift] :optional [:caps_lock]}} :1]
    [{:key :2 :modi {:mandatory [:shift] :optional [:caps_lock]}} :2]
    [{:key :3 :modi {:mandatory [:shift] :optional [:caps_lock]}} :3]
    [{:key :4 :modi {:mandatory [:shift] :optional [:caps_lock]}} :4]
    [{:key :5 :modi {:mandatory [:shift] :optional [:caps_lock]}} :5]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0]
   ]}

  {:des "Brackets to command+bracket"
   :rules [
    [{:key :open_bracket :modi {:optional [:caps_lock]}} :!Copen_bracket]
    [{:key :close_bracket :modi {:optional [:caps_lock]}} :!Cclose_bracket]
    [{:key :open_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :open_bracket]
    [{:key :close_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :close_bracket]
   ]}

  {:des "Swap backslash and pipe"
   :rules [
    [:!Sbackslash :backslash]
    [{:key :backslash :modi {:mandatory []}} :!Sbackslash]
   ]}

  {:des "Left shift to open paren when alone"
   :rules [
    [:##left_shift :left_shift nil {:alone :!S9}]
   ]}

  {:des "Right shift to close paren when alone"
   :rules [
    [:##right_shift :right_shift nil {:alone :!S0}]
   ]}

  ;; =====================================================================
  ;; DESKTOP ONLY
  ;; =====================================================================

  {:des "[Desktop] Page down/up to click/right click"
   :rules [:Desktop
    [:##page_down :button1]
    [:##page_up :button2]
   ]}

  {:des "[Desktop] Right command + brackets to ctrl-tab navigation"
   :rules [:Desktop
    [{:key :open_bracket :modi {:mandatory [:right_command]}} :!TStab]
    [{:key :close_bracket :modi {:mandatory [:right_command]}} :!Ttab]
   ]}

  {:des "[Desktop] Left/right arrows to backspace/delete"
   :rules [:Desktop
    [:##left_arrow :delete_or_backspace]
    [:##right_arrow :delete_forward]
   ]}

  {:des "[Desktop] Right command to close curly/bracket when alone"
   :rules [:Desktop
    [:right_command :right_command nil {:alone :!Sclose_bracket}]
    [{:key :right_command :modi {:mandatory [:shift]}} {:key :right_command :modi [:left_shift]} nil {:alone :close_bracket}]
   ]}

  {:des "[Desktop] Left command to open curly/bracket when alone"
   :rules [:Desktop
    [:left_command :left_command nil {:alone :!Sopen_bracket}]
    [:!Sleft_command {:key :left_command :modi [:left_shift]} nil {:alone :open_bracket}]
   ]}

  {:des "[Desktop] Arrow navigation with right command"
   :rules [:Desktop
    ;; right_command + j = option + left (word left)
    [{:key :j :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:right_option]}]
    ;; right_command + k = option + right (word right)
    [{:key :k :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:right_option]}]
    ;; right_command + m = command + left (line start)
    [{:key :m :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:left_command]}]
    ;; right_command + comma = command + right (line end)
    [{:key :comma :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:left_command]}]
    ;; right_command + up = left
    [{:key :up_arrow :modi {:mandatory [:right_command] :optional [:any]}} :left_arrow]
    ;; right_command + down = right
    [{:key :down_arrow :modi {:mandatory [:right_command] :optional [:any]}} :right_arrow]
   ]}

  {:des "[Desktop] Space + keys for text selection"
   :rules [:Desktop
    ;; Spacebar sets variable when held, outputs space when tapped alone
    [:spacebar ["space_held" 1] nil {:alone :spacebar :afterup ["space_held" 0]}]
    ;; Space+J = Shift+Option+Left (select word left)
    [:j {:key :left_arrow :modi [:left_shift :right_option]} ["space_held" 1]]
    ;; Space+K = Shift+Option+Right (select word right)
    [:k {:key :right_arrow :modi [:left_shift :right_option]} ["space_held" 1]]
    ;; Space+M = Shift+Command+Left (select to line start)
    [:m {:key :left_arrow :modi [:left_shift :left_command]} ["space_held" 1]]
    ;; Space+Comma = Shift+Command+Right (select to line end)
    [:comma {:key :right_arrow :modi [:left_shift :left_command]} ["space_held" 1]]
    ;; Space+Up = Shift+Left (select char left)
    [:up_arrow {:key :left_arrow :modi [:left_shift]} ["space_held" 1]]
    ;; Space+Down = Shift+Right (select char right)
    [:down_arrow {:key :right_arrow :modi [:left_shift]} ["space_held" 1]]
    ;; Space+N = Escape
    [:n :escape ["space_held" 1]]
    ;; Space+H = Command+K (Chrome only)
    [:h :!Ck :Chrome ["space_held" 1]]
   ]}

  {:des "[Desktop] Backspace to super, delete to hyper"
   :rules [:Desktop
    ;; Backspace = super (cmd+shift+ctrl), alone = super+7
    [:##delete_or_backspace {:key :left_command :modi [:left_shift :left_control]} nil {:alone {:key :7 :modi [:left_command :left_shift :left_control]}}]
    ;; Delete forward = hyper, but exits layer_n when tapped alone in that layer
    [:##delete_forward {:key :left_command :modi [:left_shift :left_control :left_option]} nil {:alone [["layer_n" 0] {:noti {:id "layer_n" :text ""}}]}]
   ]}

  {:des "[Desktop] Swap equals and backtick"
   :rules [:Desktop
    [{:key :equal_sign :modi {:optional [:caps_lock]}} :grave_accent_and_tilde]
    [{:key :grave_accent_and_tilde :modi {:optional [:caps_lock]}} :equal_sign]
    [{:key :equal_sign :modi {:mandatory [:shift] :optional [:caps_lock]}} :!Sgrave_accent_and_tilde]
    [{:key :grave_accent_and_tilde :modi {:mandatory [:shift] :optional [:caps_lock]}} :!Sequal_sign]
   ]}

  {:des "[Desktop] Home to enter"
   :rules [:Desktop
    [:home :return_or_enter]
   ]}

  {:des "[Desktop] Single quote to control when held"
   :rules [:Desktop
    [:##quote :left_control nil {:alone :quote}]
   ]}

  {:des "[Desktop] Right control+H to F9 (text-to-speech)"
   :rules [:Desktop
    [{:key :h :modi {:mandatory [:right_control]}} :f9]
   ]}

  {:des "[Desktop] Right control+Y to Shift+F9 (toggle recording)"
   :rules [:Desktop
    [{:key :y :modi {:mandatory [:right_control]}} :!Sf9]
   ]}

  {:des "[Desktop] Layer N (right_control+N to enter)"
   :rules [:Desktop
    ;; right_control+N enters layer_n
    [{:key :n :modi {:mandatory [:right_control]}} [["layer_n" 1] {:shell "echo n > /tmp/karabiner-layer"}] ["layer_n" 0]]
    ;; escape exits layer_n
    [:escape [["layer_n" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_n" 1]]
    ;; right_control alone exits layer_n
    [:right_control [["layer_n" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_n" 1]]
    ;; Layer N shortcuts
    [:return_or_enter [:!Cgrave_accent_and_tilde ["layer_n" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_n" 1]]
    [:spacebar [:!CTOSg ["layer_n" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_n" 1]]
    [:up_arrow [:!CTOSv ["layer_n" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_n" 1]]
    [:down_arrow [:!CTOSb ["layer_n" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_n" 1]]
    [:m [{:shell "/Users/rbalicki/code/voicemode/chrome-tab.sh personal && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:comma [{:shell "/Users/rbalicki/code/voicemode/chrome-tab.sh work && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:y [{:shell "/Users/rbalicki/code/voicemode/chrome-tab.sh personal 1 && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:u [{:shell "/Users/rbalicki/code/voicemode/chrome-tab.sh personal 2 && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:i [{:shell "/Users/rbalicki/code/voicemode/chrome-tab.sh work 1 && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:o [{:shell "/Users/rbalicki/code/voicemode/chrome-tab.sh work 2 && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:j [{:shell "open -a 'iTerm' && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:k [{:shell "open -a 'Visual Studio Code' && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:h [{:shell "open -a 'Karabiner-EventViewer' && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
    [:l [{:shell "open -a 'Signal' && echo > /tmp/karabiner-layer"} ["layer_n" 0]] ["layer_n" 1]]
   ]}

  {:des "[Desktop] Layer M (right_control+M to enter)"
   :rules [:Desktop
    ;; right_control+M enters layer_m
    [{:key :m :modi {:mandatory [:right_control]}} [["layer_m" 1] {:shell "echo m > /tmp/karabiner-layer"}] ["layer_m" 0]]
    ;; escape exits layer_m
    [:escape [["layer_m" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_m" 1]]
    ;; right_control alone exits layer_m
    [:right_control [["layer_m" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_m" 1]]
    ;; Layer M shortcuts
    [:m [:!Tc ["layer_m" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_m" 1]]
    [:n [:!Tr ["layer_m" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_m" 1]]
    [:h [:!Cc ["layer_m" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_m" 1]]
    [:j [:!Cv ["layer_m" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_m" 1]]
   ]}

  {:des "[Desktop] Chrome Layer (right_control+J to enter, Chrome only)"
   :rules [:Desktop
    ;; right_control+J enters layer_chrome (Chrome only)
    [{:key :j :modi {:mandatory [:right_control]}} [["layer_chrome" 1] {:shell "echo chrome > /tmp/karabiner-layer"}] :Chrome ["layer_chrome" 0]]
    ;; escape exits layer
    [:escape [["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; right_control alone exits layer
    [:right_control [["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; H = Command+T (new tab) - exits layer
    [:h [:!Ct ["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; J = Control+Shift+Tab (previous tab) - stays in layer
    [:j :!TStab ["layer_chrome" 1]]
    ;; K = Control+Tab (next tab) - stays in layer
    [:k :!Ttab ["layer_chrome" 1]]
    ;; L = Command+Shift+A
    [:l [:!CSa ["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; Y = Command+1
    [:y [:!C1 ["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; U = Command+2
    [:u [:!C2 ["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; I = Command+3
    [:i [:!C3 ["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; O = Command+4
    [:o [:!C4 ["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
    ;; P = Command+9
    [:p [:!C9 ["layer_chrome" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_chrome" 1]]
   ]}

  {:des "[Desktop] Tmux Layer (right_control+J to enter, iTerm only)"
   :rules [:Desktop
    ;; right_control+J sends Control+A and enters tmux layer (iTerm only)
    [{:key :j :modi {:mandatory [:right_control]}} [:!Ta ["layer_tmux" 1] {:shell "echo tmux > /tmp/karabiner-layer"}] :iTerm ["layer_tmux" 0]]
    ;; escape exits layer
    [:escape [["layer_tmux" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_tmux" 1]]
    ;; right_control alone exits layer
    [:right_control [["layer_tmux" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_tmux" 1]]
    ;; Y-P → !, @, #, $, % (tmux windows 1-5) + exit
    [:y [:!S1 ["layer_tmux" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_tmux" 1]]
    [:u [:!S2 ["layer_tmux" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_tmux" 1]]
    [:i [:!S3 ["layer_tmux" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_tmux" 1]]
    [:o [:!S4 ["layer_tmux" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_tmux" 1]]
    [:p [:!S5 ["layer_tmux" 0] {:shell "echo > /tmp/karabiner-layer"}] ["layer_tmux" 1]]
   ]}

 ] ;; end :main

} ;; end config
