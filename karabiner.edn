;; Goku config - 1:1 conversion of karabiner.json
;; Run `goku` after editing to regenerate karabiner.json
;;
;; Modifier key legend:
;;   ! = mandatory modifier
;;   # = optional modifier
;;   C = left_command, Q = right_command
;;   T = left_control (NOT right_control - use full form for that)
;;   O = left_option,  E = right_option
;;   S = left_shift,   R = right_shift
;;   W = fn
;;
;; ## = :optional ["any"]
;; For right_control, use: {:key :x :modi {:mandatory [:right_control]}}

{
 :profiles {
  :Default {
   :default true
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
  :None {
   :default false
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
 }

 ;; Device definitions for conditional rules
 ;; :apple_internal = MacBook built-in keyboard (rules with :!apple_internal apply to external keyboards only)
 :devices {
  :apple_internal [{:vendor_id 1452 :product_id 835 :is_keyboard true}]
  :trackball [{:vendor_id 10730 :product_id 258 :is_pointing_device true}]
  :logitech [{:vendor_id 1133 :product_id 45921 :is_keyboard true :is_pointing_device true}]
 }

 :applications {
  :iTerm ["com.googlecode.iterm2"]
  :Chrome ["com.google.Chrome"]
  :VSCode ["com.microsoft.VSCode"]
 }

 :simlayers {
 }

 ;; Templates reduce repetition in shell commands
 ;; Usage: [:layer "norm"] expands to {:shell "echo norm > /tmp/karabiner-layer"}
 :templates {
  ;; Layer indicator (writes to /tmp/karabiner-layer for SwiftBar/Hammerspoon)
  :layer "echo %s > /tmp/karabiner-layer"
  ;; App launching
  :open-norm "open -a '%s' && echo norm > /tmp/karabiner-layer"
  ;; Git/terminal typing (Term layer) - exits to Ins mode
  :type-ins "osascript -e 'tell app \"System Events\" to keystroke \"%s\"' && echo ins > /tmp/karabiner-layer"
  :type-enter-ins "osascript -e 'tell app \"System Events\" to keystroke \"%s\"' -e 'tell app \"System Events\" to key code 36' && echo ins > /tmp/karabiner-layer"
  ;; Chrome tab by index
  :chrome-tab "osascript -e 'tell application \"Google Chrome\" to set active tab index of front window to %s' && echo norm > /tmp/karabiner-layer"
  ;; Chrome profile switching
  :chrome-profile "/Users/rbalicki/code/voicemode/chrome-tab.sh %s && echo norm > /tmp/karabiner-layer"
 }

 :main [

  ;; =====================================================================
  ;; LAYER VARIABLE SYSTEM - READ BEFORE ADDING TRANSITIONS
  ;; =====================================================================
  ;;
  ;; Three states controlled by layer_normal and in_any_layer:
  ;;   Normal:       layer_normal=1, in_any_layer=0  (layer selector)
  ;;   Ins:          layer_normal=0, in_any_layer=0  (typing passthrough)
  ;;   Modal layers: layer_normal=0, in_any_layer=1  (keys remapped/disabled)
  ;;
  ;; REQUIRED for Normal → Ins:
  ;;   ["layer_ins" 1] ["layer_normal" 0] ["in_any_layer" 0]
  ;;
  ;; REQUIRED for Normal → Modal (Nav, L, etc.):
  ;;   ["layer_X" 1] ["layer_normal" 0] ["in_any_layer" 1]
  ;;
  ;; REQUIRED for Any → Normal:
  ;;   ["layer_X" 0] ["in_any_layer" 0] ["layer_normal" 1]
  ;;
  ;; ALWAYS write layer name to /tmp/karabiner-layer for SwiftBar
  ;; =====================================================================

  ;; =====================================================================
  ;; NONE PROFILE - Empty escape hatch (dummy rule to make Goku create it)
  ;; =====================================================================

  {:des "None profile placeholder"
   :rules [:None
    ;; Map an unused key to itself so Goku creates this profile
    [:non_us_backslash :non_us_backslash]
   ]}

  ;; =====================================================================
  ;; ALL PROFILES - Common rules (no profile condition)
  ;; =====================================================================

  {:des "Caps lock to control/escape"
   :rules [
    [:##caps_lock :left_control nil {:alone :escape}]
   ]}

  {:des "Cmd+PageUp = Escape (global)"
   :rules [
    [:!Cpage_up :escape]
    [:!Qpage_up :escape]
   ]}

  {:des "TEMPORARY: F21 (Fn+hk4) = show overlay"
   :rules [
    [:f21 {:shell "/opt/homebrew/bin/hs -c 'showLayerOverlay()'"}]
   ]}

  {:des "Shift+mirror oneshot numbers (must come before number swap)"
   :rules [
    ;; RHS numbers in shift_mirror_oneshot: mirror to LHS position, output digit
    [:6 [:5 ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:7 [:4 ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:8 [:3 ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:9 [:2 ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
    [:0 [:1 ["shift_mirror_oneshot" 0]] ["shift_mirror_oneshot" 1]]
   ]}

  {:des "Exchange numbers and symbols (laptop only)"
   :rules [:apple_internal
    [{:key :1 :modi {:optional [:caps_lock]}} :!S1]
    [{:key :2 :modi {:optional [:caps_lock]}} :!S2]
    [{:key :3 :modi {:optional [:caps_lock]}} :!S3]
    [{:key :4 :modi {:optional [:caps_lock]}} :!S4]
    [{:key :5 :modi {:optional [:caps_lock]}} :!S5]
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0]
    [{:key :1 :modi {:mandatory [:shift] :optional [:caps_lock]}} :1]
    [{:key :2 :modi {:mandatory [:shift] :optional [:caps_lock]}} :2]
    [{:key :3 :modi {:mandatory [:shift] :optional [:caps_lock]}} :3]
    [{:key :4 :modi {:mandatory [:shift] :optional [:caps_lock]}} :4]
    [{:key :5 :modi {:mandatory [:shift] :optional [:caps_lock]}} :5]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0]
   ]}

  {:des "Numbers to symbols (Desktop RHS 6-0, Ins mode only)"
   :rules [:!apple_internal
    ;; Bare number → symbol (only in Ins mode where typing happens)
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6 ["layer_ins" 1]]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7 ["layer_ins" 1]]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8 ["layer_ins" 1]]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9 ["layer_ins" 1]]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0 ["layer_ins" 1]]
    ;; Shift+number → digit (like laptop)
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6 ["layer_ins" 1]]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7 ["layer_ins" 1]]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8 ["layer_ins" 1]]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9 ["layer_ins" 1]]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0 ["layer_ins" 1]]
   ]}

  {:des "Shift+up/down = square brackets (Desktop Ins mode)"
   :rules [:!apple_internal
    [{:key :up_arrow :modi {:mandatory [:shift]}} :open_bracket ["layer_ins" 1]]
    [{:key :down_arrow :modi {:mandatory [:shift]}} :close_bracket ["layer_ins" 1]]
   ]}

  {:des "Brackets to command+bracket (only in working layers)"
   :rules [
    [{:key :open_bracket :modi {:optional [:caps_lock]}} :!Copen_bracket ["in_any_layer" 1]]
    [{:key :close_bracket :modi {:optional [:caps_lock]}} :!Cclose_bracket ["in_any_layer" 1]]
    ;; Cmd+bracket → bare bracket (only in working layers, blocked in Normal)
    [{:key :open_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :open_bracket ["in_any_layer" 1]]
    [{:key :close_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :close_bracket ["in_any_layer" 1]]
    ;; Shift+brackets have no special mapping (pass through naturally)
   ]}

  {:des "Backslash in Ins mode"
   :rules [
    ;; backslash = tab in Ins mode
    [:backslash :tab ["layer_ins" 1]]
   ]}

  ;; Backslash/pipe pass through naturally (no swap)

  {:des "Left shift to open paren when alone (laptop only)"
   :rules [:apple_internal
    [:##left_shift :left_shift ["in_any_layer" 1] {:alone :!S9}]
   ]}

  {:des "Right shift to close paren when alone (laptop only)"
   :rules [:apple_internal
    [:##right_shift :right_shift ["in_any_layer" 1] {:alone :!S0}]
   ]}

  ;; =====================================================================
  ;; DESKTOP ONLY
  ;; =====================================================================

  {:des "[Desktop] Disable LHS keys and arrows"
   :rules [:!apple_internal
    [:##grave_accent_and_tilde :vk_none]  ;; physical backtick
    [:##non_us_backslash :vk_none]  ;; § key
    [:##left_arrow :vk_none]
    [:##right_arrow :vk_none]
    [:##q :vk_none]
    [:##w :vk_none]
    [:##e :vk_none]
    [:##r :vk_none]
    [:##t :vk_none]
    [:##a :vk_none]
    [:##s :vk_none]
    [:##d :vk_none]
    [:##f :vk_none]
    [:##g :vk_none]
    [:##z :vk_none]
    [:##x :vk_none]
    [:##c :vk_none]
    [:##v :vk_none]
    [:##b :vk_none]
   ]}

  {:des "[Desktop] Page down/up to click/right click"
   :rules [:!apple_internal
    ;; Exclude when in Cmd sub-layer (it handles Cmd+click)
    ;; No ## so Cmd+PageUp can still trigger escape rule
    [:page_down :button1 ["layer_l_cmd" 0]]
    [:page_up :button2 ["layer_l_cmd" 0]]
   ]}

  {:des "[Desktop] Right command + brackets to ctrl-tab navigation"
   :rules [:!apple_internal
    [{:key :open_bracket :modi {:mandatory [:right_command]}} :!TStab]
    [{:key :close_bracket :modi {:mandatory [:right_command]}} :!Ttab]
   ]}

  {:des "[Desktop] Right control + brackets to backspace/delete"
   :rules [:!apple_internal
    [{:key :open_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_or_backspace :modi []}]
    [{:key :close_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_forward :modi []}]
   ]}

  
  {:des "[Desktop] rcmd+H chord (delete) - Ins mode only"
   :rules [:!apple_internal
    ;; rcmd+H sets rcmd_h_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :h :modi {:mandatory [:right_command]}} [{:shell ":"} ["rcmd_h_mode" 1]] ["layer_ins" 1] {:afterup [["rcmd_h_mode" 0]]}]
    ;; While rcmd_h_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!Odelete_or_backspace ["rcmd_h_mode" 1]]      ;; J = del word left
    [{:key :k :modi {:mandatory [:right_command]}} :!Odelete_forward ["rcmd_h_mode" 1]]          ;; K = del word right
    [{:key :m :modi {:mandatory [:right_command]}} :!Cdelete_or_backspace ["rcmd_h_mode" 1]]     ;; M = del to line start
    [{:key :comma :modi {:mandatory [:right_command]}} :!Tk ["rcmd_h_mode" 1]]                   ;; , = del to line end
    [{:key :up_arrow :modi {:mandatory [:right_command]}} :delete_or_backspace ["rcmd_h_mode" 1]] ;; up = del char left
    [{:key :down_arrow :modi {:mandatory [:right_command]}} :delete_forward ["rcmd_h_mode" 1]]   ;; down = del char right
   ]}

  {:des "[Desktop] rcmd+N chord (select) - Ins mode only"
   :rules [:!apple_internal
    ;; rcmd+N sets rcmd_n_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :n :modi {:mandatory [:right_command]}} [{:shell ":"} ["rcmd_n_mode" 1]] ["layer_ins" 1] {:afterup [["rcmd_n_mode" 0]]}]
    ;; While rcmd_n_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!SOleft_arrow ["rcmd_n_mode" 1]]             ;; J = sel word left
    [{:key :k :modi {:mandatory [:right_command]}} :!SOright_arrow ["rcmd_n_mode" 1]]            ;; K = sel word right
    [{:key :m :modi {:mandatory [:right_command]}} :!SCleft_arrow ["rcmd_n_mode" 1]]             ;; M = sel to line start
    [{:key :comma :modi {:mandatory [:right_command]}} :!SCright_arrow ["rcmd_n_mode" 1]]        ;; , = sel to line end
    [{:key :up_arrow :modi {:mandatory [:right_command]}} :!Sleft_arrow ["rcmd_n_mode" 1]]       ;; up = sel char left
    [{:key :down_arrow :modi {:mandatory [:right_command]}} :!Sright_arrow ["rcmd_n_mode" 1]]    ;; down = sel char right
   ]}

  {:des "[Desktop] Arrow navigation with right command (Ins mode only)"
   :rules [:!apple_internal
    ;; right_command + j = option + left (word left)
    [{:key :j :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:right_option]} ["layer_ins" 1]]
    ;; right_command + k = option + right (word right)
    [{:key :k :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:right_option]} ["layer_ins" 1]]
    ;; right_command + m = command + left (line start)
    [{:key :m :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:left_command]} ["layer_ins" 1]]
    ;; right_command + comma = command + right (line end)
    [{:key :comma :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:left_command]} ["layer_ins" 1]]
    ;; right_command + up = left
    [{:key :up_arrow :modi {:mandatory [:right_command] :optional [:any]}} :left_arrow ["layer_ins" 1]]
    ;; right_command + down = right
    [{:key :down_arrow :modi {:mandatory [:right_command] :optional [:any]}} :right_arrow ["layer_ins" 1]]
   ]}

  {:des "[Desktop] Disable backspace and delete keys"
   :rules [:!apple_internal
    [:##delete_or_backspace :vk_none]
    [:##delete_forward :vk_none]
   ]}

  {:des "[Desktop] Physical equals to backtick"
   :rules [:!apple_internal
    ;; Physical backtick is disabled globally
    ;; Physical equals → backtick
    [{:key :equal_sign :modi {:optional [:any]}} :grave_accent_and_tilde]
    ;; Shift + physical equals → tilde
    [{:key :equal_sign :modi {:mandatory [:shift] :optional [:any]}} :!Sgrave_accent_and_tilde]
   ]}


  {:des "[Desktop] Right control+N to Escape (all layers)"
   :rules [:!apple_internal
    [{:key :n :modi {:mandatory [:right_control]}} :escape]
   ]}

  {:des "[Desktop] Right control+6 to F9 (text-to-speech)"
   :rules [:!apple_internal
    [{:key :6 :modi {:mandatory [:right_control]}} [:f9 ["layer_ins" 1] ["layer_normal" 0] ["in_any_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}]]
   ]}

  {:des "[Desktop] Wispr Flow shortcut"
   :rules [:!apple_internal
    ;; right_control+Y → Ctrl+Alt+Shift+F19 (popo) → exit to Ins
    [{:key :y :modi {:mandatory [:right_control]}} [["layer_ins" 1] ["layer_normal" 0] ["in_any_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["layer_l" 0] {:afterup [:!TOSf19]}]
   ]}

  {:des "[Desktop] Ctrl+hk4 (Alt+F22) enters Nav from any layer"
   :rules [:!apple_internal
    ;; Ctrl+hk4 enters Nav, clearing other layers
    [:!Of22 [["layer_ins" 0] ["layer_n" 1] ["layer_normal" 0] ["in_any_layer" 1]
             ["layer_i" 0] ["layer_comma" 0] ["layer_l" 0] ["layer_term" 0]
             ["layer_chrome" 0] ["layer_vscode" 0] ["layer_tmux" 0]
             [:layer "n"]]]
   ]}

  {:des "[Desktop] Layer N (hk4 from Normal to enter, N = escape in Normal)"
   :rules [:!apple_internal
    ;; N in Normal = escape (stays in Normal)
    [:n :escape ["layer_normal" 1]]
    ;; hk4 (Alt+F20) enters Nav from Normal
    [:!Of20 [["layer_n" 1] ["layer_normal" 0] ["in_any_layer" 1] [:layer "n"]] ["layer_normal" 1]]
    [:right_control :right_control ["layer_n" 1] {:alone [["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1] [:layer "norm"]]}]
    [{:key :j :modi {:mandatory [:control]}} [["layer_n" 0] ["in_any_layer" 0] ["layer_ins" 1] [:layer "ins"]] ["layer_n" 1]]
    ;; Shortcuts
    [{:key :h :modi {:mandatory [:right_control]}} :!Cw ["layer_n" 1]]  ;; Close (stays)
    ;; App launching
    [:h [[:open-norm "iTerm"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:j [[:open-norm "Visual Studio Code"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:k [[:open-norm "Karabiner-EventViewer"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    ;; Chrome profiles
    [:n [[:chrome-profile "personal"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:m [[:chrome-profile "work"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:l [[:open-norm "Signal"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:!Of1 [[:open-norm "Messages"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]  ;; Fn+L
    [{:key :l :modi {:mandatory [:right_control]}} [[:open-norm "WhatsApp"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:o [[:open-norm "Obsidian"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:y [:!Cspacebar ["layer_n" 0] ["in_any_layer" 0] ["layer_ins" 1] [:layer "ins"]] ["layer_n" 1]]  ;; Spotlight → Ins mode
    ;; Finder
    [:period [[:open-norm "Finder"] ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]
    [:!Of7 [{:shell "open -a 'Finder' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"g\" using {command down, shift down}' && echo norm > /tmp/karabiner-layer"} ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]  ;; Fn+Period: Go to Folder
    [{:key :period :modi {:mandatory [:right_control]}} [{:shell "open -a 'Finder' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"g\" using {command down, shift down}' && sleep 0.1 && osascript -e 'tell app \"System Events\" to keystroke \"v\" using command down' -e 'tell app \"System Events\" to key code 36' && echo norm > /tmp/karabiner-layer"} ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 1]] ["layer_n" 1]]  ;; Ctrl+Period: Go to Folder + Paste
    ;; Fn+navigation shortcuts (stay in layer)
    [:f23 :!Copen_bracket ["layer_n" 1]]  ;; Fn+J: Back
    [:f24 :!Cclose_bracket ["layer_n" 1]]  ;; Fn+K: Forward
    [:!Of5 :!TStab ["layer_n" 1]]  ;; Fn+M: Prev tab
    [:!Of6 :!Ttab ["layer_n" 1]]  ;; Fn+Comma: Next tab
    [:!Of9 :!Ctab ["layer_n" 1]]  ;; Fn+Up: App switch fwd
    [:!Of10 :!CStab ["layer_n" 1]]  ;; Fn+Down: App switch back
    ;; Enter = Cmd+Enter (exits to Ins)
    [:return_or_enter [:!Creturn_or_enter ["layer_n" 0] ["in_any_layer" 0] ["layer_normal" 0] ["layer_ins" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["layer_n" 1]]
   ]}

  {:des "[Desktop] Mouse Mode 🐭 (M/Fn+M from Normal, Ctrl+M from Ins)"
   :rules [:!apple_internal
    ;; === ENTRY ===
    ;; M from Normal: enter Mouse mode, set mouse_from_ins=0, trigger Homerow
    [:m [["layer_mouse" 1] ["mouse_from_ins" 0] ["layer_normal" 0] ["in_any_layer" 1] :!COSo {:shell "echo mouse > /tmp/karabiner-layer"}] ["layer_normal" 1]]
    ;; Fn+M (Alt+F5) from Normal: enter Mouse mode, set mouse_from_ins=0, start warpd grid
    [:!Of5 [["layer_mouse" 1] ["mouse_from_ins" 0] ["layer_normal" 0] ["in_any_layer" 1] {:shell "pkill -9 warpd 2>/dev/null; /usr/local/bin/warpd --grid -c /Users/rbalicki/code/voicemode/warpd.conf & echo mouse > /tmp/karabiner-layer"}] ["layer_normal" 1]]
    ;; Ctrl+M from Ins: enter Mouse mode, set mouse_from_ins=1, trigger Homerow
    [{:key :m :modi {:mandatory [:right_control]}} [["layer_mouse" 1] ["mouse_from_ins" 1] ["layer_ins" 0] ["in_any_layer" 1] :!COSo {:shell "echo mouse > /tmp/karabiner-layer"}] ["layer_ins" 1]]

    ;; === EXIT (return to origin) ===
    ;; Uses rule ordering: mouse_from_ins=1 rules first (exit to Ins), then fallback (exit to Normal)
    ;; All exits clear mouse_from_ins=0

    ;; Cancel: right_control = Escape
    [:right_control [:escape ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_ins" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["mouse_from_ins" 1]]
    [:right_control [:escape ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_normal" 1] {:shell "echo norm > /tmp/karabiner-layer"}] ["layer_mouse" 1]]

    ;; Space = Enter (left click)
    [:spacebar [:return_or_enter ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_ins" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["mouse_from_ins" 1]]
    [:spacebar [:return_or_enter ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_normal" 1] {:shell "echo norm > /tmp/karabiner-layer"}] ["layer_mouse" 1]]

    ;; Fn+Space = Cmd+Enter (Cmd+click, e.g. open link in new tab)
    [:!Of18 [:!Creturn_or_enter ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_ins" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["mouse_from_ins" 1]]
    [:!Of18 [:!Creturn_or_enter ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_normal" 1] {:shell "echo norm > /tmp/karabiner-layer"}] ["layer_mouse" 1]]

    ;; Shift+Space = Shift+Enter (right click) - use :shift to match either shift key
    [{:key :spacebar :modi {:mandatory [:shift]}} [:!Sreturn_or_enter ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_ins" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["mouse_from_ins" 1]]
    [{:key :spacebar :modi {:mandatory [:shift]}} [:!Sreturn_or_enter ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_normal" 1] {:shell "echo norm > /tmp/karabiner-layer"}] ["layer_mouse" 1]]

    ;; Shift+Enter = Shift+Click (extend selection) - use :shift to match either shift key
    ;; Must come before bare Enter rule
    [{:key :return_or_enter :modi {:mandatory [:shift]}} [:!Sreturn_or_enter ["layer_mouse" 0] ["mouse_from_ins" 0] ["in_any_layer" 0] ["layer_ins" 1] {:shell "echo ins > /tmp/karabiner-layer"}] ["mouse_from_ins" 1]]
