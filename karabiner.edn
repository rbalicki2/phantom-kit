    [:j [["mode" 1] ["in_modal" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["mode" 0]]
    ;; Y from Normal = Ctrl+Alt+Shift+F19 (Wispr popo) + enter Ins
    [:y [:!TOSf19 ["mode" 1] ["in_modal" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["mode" 0]]
    ;; 6 from Normal = F9 (TTS) + enter Ins
    [:6 [:f9 ["mode" 1] ["in_modal" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["mode" 0]]
    ;; Block Ctrl+J in Ins mode (otherwise it types a newline)
    [{:key :j :modi {:mandatory [:control]}} :vk_none ["mode" 1]]
    ;; right_control alone exits Ins to Normal
    [:right_control :right_control ["mode" 1] {:alone [["mode" 0] ["in_modal" 0] ["submode" 0] ["submode" 0] {:shell "echo norm > /tmp/karabiner-layer"}]}]
    ;; Fn+] (Alt+F12) = enter shift_mirror_oneshot mode
    [:!Of12 [["submode" 1]] ["mode" 1]]
