;; Goku config - 1:1 conversion of karabiner.json
;; Run `goku` after editing to regenerate karabiner.json
;;
;; Modifier key legend:
;;   ! = mandatory modifier
;;   # = optional modifier
;;   C = left_command, Q = right_command
;;   T = left_control (NOT right_control - use full form for that)
;;   O = left_option,  E = right_option
;;   S = left_shift,   R = right_shift
;;   W = fn
;;
;; ## = :optional ["any"]
;; For right_control, use: {:key :x :modi {:mandatory [:right_control]}}

{
 :profiles {
  :Default {
   :default true
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
  :None {
   :default false
   :sim 50
   :delay 80
   :alone 150
   :held 70
  }
 }

 ;; Device definitions for conditional rules
 ;; :apple_internal = MacBook built-in keyboard (rules with :!apple_internal apply to external keyboards only)
 :devices {
  :apple_internal [{:vendor_id 1452 :product_id 835 :is_keyboard true}]
  :trackball [{:vendor_id 10730 :product_id 258 :is_pointing_device true}]
  :logitech [{:vendor_id 1133 :product_id 45921 :is_keyboard true :is_pointing_device true}]
 }

 :applications {
  :iTerm ["com.googlecode.iterm2"]
  :Chrome ["com.google.Chrome"]
  :VSCode ["com.microsoft.VSCode"]
 }

 :simlayers {
 }

 ;; Templates reduce repetition in shell commands
 ;; Usage: [:layer "norm"] expands to {:shell "echo norm > /tmp/karabiner-layer"}
 :templates {
  ;; Layer indicator (writes to /tmp/karabiner-layer for SwiftBar/Hammerspoon)
  :layer "echo %s > /tmp/karabiner-layer"
  ;; App launching
  :open-norm "open -a '%s' && echo norm > /tmp/karabiner-layer"
  ;; Git/terminal typing (Term layer) - sends Ctrl+C first, exits to Ins mode
  :type-ins "osascript -e 'tell app \"System Events\" to key code 8 using control down' -e 'tell app \"System Events\" to keystroke \"%s\"' && echo ins > /tmp/karabiner-layer"
  :type-enter-ins "osascript -e 'tell app \"System Events\" to key code 8 using control down' -e 'tell app \"System Events\" to keystroke \"%s\"' -e 'tell app \"System Events\" to key code 36' && echo ins > /tmp/karabiner-layer"
  ;; Chrome tab by index
  :chrome-tab "osascript -e 'tell application \"Google Chrome\" to set active tab index of front window to %s' && echo norm > /tmp/karabiner-layer"
  ;; Chrome profile switching
  :chrome-profile "/Users/rbalicki/code/voicemode/chrome-tab.sh %s && echo norm > /tmp/karabiner-layer"
 }

 :main [

  ;; =====================================================================
  ;; NONE PROFILE - Empty escape hatch (dummy rule to make Goku create it)
  ;; =====================================================================

  {:des "None profile placeholder"
   :rules [:None
    ;; Map an unused key to itself so Goku creates this profile
    [:non_us_backslash :non_us_backslash]
   ]}

  ;; =====================================================================
  ;; LAPTOP ONLY (apple_internal)
  ;; =====================================================================

  {:des "Caps lock to control/escape (laptop only)"
   :rules [:apple_internal
    [:##caps_lock :left_control nil {:alone :escape}]
   ]}

  {:des "Exchange numbers and symbols (laptop only)"
   :rules [:apple_internal
    [{:key :1 :modi {:optional [:caps_lock]}} :!S1]
    [{:key :2 :modi {:optional [:caps_lock]}} :!S2]
    [{:key :3 :modi {:optional [:caps_lock]}} :!S3]
    [{:key :4 :modi {:optional [:caps_lock]}} :!S4]
    [{:key :5 :modi {:optional [:caps_lock]}} :!S5]
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0]
    [{:key :1 :modi {:mandatory [:shift] :optional [:caps_lock]}} :1]
    [{:key :2 :modi {:mandatory [:shift] :optional [:caps_lock]}} :2]
    [{:key :3 :modi {:mandatory [:shift] :optional [:caps_lock]}} :3]
    [{:key :4 :modi {:mandatory [:shift] :optional [:caps_lock]}} :4]
    [{:key :5 :modi {:mandatory [:shift] :optional [:caps_lock]}} :5]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0]
   ]}

  {:des "Left shift to open paren when alone (laptop only)"
   :rules [:apple_internal
    [:##left_shift :left_shift nil {:alone :!S9}]
   ]}

  {:des "Right shift to close paren when alone (laptop only)"
   :rules [:apple_internal
    [:##right_shift :right_shift nil {:alone :!S0}]
   ]}

  ;; =====================================================================
  ;; DESKTOP GLOBAL - Utility rules not affected by mode variables
  ;; =====================================================================

  {:des "[Desktop Global] Disable LHS keys and arrows"
   :rules [:!apple_internal
    [:##grave_accent_and_tilde :vk_none]
    [:##non_us_backslash :vk_none]
    [:##left_arrow :vk_none]
    [:##right_arrow :vk_none]
    [:##q :vk_none]
    [:##w :vk_none]
    [:##e :vk_none]
    [:##r :vk_none]
    [:##t :vk_none]
    [:##a :vk_none]
    [:##s :vk_none]
    [:##d :vk_none]
    [:##f :vk_none]
    [:##g :vk_none]
    [:##z :vk_none]
    [:##x :vk_none]
    [:##c :vk_none]
    [:##v :vk_none]
    [:##b :vk_none]
   ]}

  {:des "[Desktop Global] hk3 (Alt+F19) = show overlay"
   :rules [:!apple_internal
    [:!Of19 {:shell "/opt/homebrew/bin/hs -c 'showLayerOverlay()'"}]
   ]}

  {:des "[Desktop Global] Fn+hk3 (Shift+Alt+F19) = PANIC BUTTON"
   :rules [:!apple_internal
    [:!SOf19 [["dsk_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_ins_sub_mode" 0] ["dsk_return_to_layer" 0]
              {:shell "pkill warpd 2>/dev/null; osascript -e 'tell app \"System Events\" to key up command' && /opt/homebrew/bin/hs -c 'scrollStop(); hoverModeStop(); dismissHomerow()' && echo norm > /tmp/karabiner-layer && date > /tmp/panic-button-test"}]]
   ]}

  {:des "[Desktop Global] Page down/up to click/right click"
   :rules [:!apple_internal
    [:page_down :button1]
    [:page_up :button2]
   ]}

  ;; =====================================================================
  ;; DESKTOP MODE-SPECIFIC - Rules organized by layer (specific to generic)
  ;; =====================================================================

  ;; =====================================================================
  ;; LAYER 0: NORMAL
  ;; =====================================================================

  {:des "[Layer 0] Normal - Entry to other layers"
   :rules [:!apple_internal
    ;; j from Normal enters Ins layer
    [:j [["dsk_layer" 1] ["dsk_in_modal_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; Y from Normal = Ctrl+Alt+Shift+F19 (Wispr popo) + enter Ins
    [:y [:!TOSf19 ["dsk_layer" 1] ["dsk_in_modal_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; 6 from Normal = F9 (TTS) + enter Ins
    [:6 [:f9 ["dsk_layer" 1] ["dsk_in_modal_layer" 0] {:shell "echo ins > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; Fn+hk4 (F21) = enter Nav layer from Normal
    [:f21 [["dsk_layer" 2] ["dsk_in_modal_layer" 1] {:shell "echo n > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; N from Normal = escape (stays in Normal)
    [:n :escape ["dsk_layer" 0]]
    ;; M from Normal: enter Label mode, trigger Homerow
    [:m [["dsk_layer" 13] ["dsk_return_to_layer" 0] ["dsk_in_modal_layer" 1] :!COSo {:shell "echo label > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; Fn+M (Alt+F5) from Normal: enter Grid mode, start warpd
    [:!Of5 [["dsk_layer" 28] ["dsk_in_modal_layer" 1] {:shell "pkill -9 warpd 2>/dev/null; /usr/local/bin/warpd --grid -c /Users/rbalicki/code/voicemode/warpd.conf & echo grid > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; i from Normal enters Admin layer
    [:i [["dsk_layer" 9] ["dsk_in_modal_layer" 1] {:shell "echo i > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; comma from Normal enters Comma layer
    [:comma [["dsk_layer" 6] ["dsk_in_modal_layer" 1] [:layer "comma"]] ["dsk_layer" 0]]
    ;; l from Normal enters L layer
    [:l [["dsk_layer" 7] ["dsk_in_modal_layer" 1] {:shell "echo l > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
    ;; u from Normal enters Term layer (focuses iTerm)
    [:u [["dsk_layer" 8] ["dsk_in_modal_layer" 1] {:shell "/Users/rbalicki/code/voicemode/term-layer-enter.sh"}] ["dsk_layer" 0]]
    ;; hk4 (Alt+F20) from Normal enters In-App Nav layer
    [:!Of20 [["dsk_layer" 10] ["dsk_in_modal_layer" 1] {:shell "echo inapp > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
   ]}

  {:des "[Layer 0] Normal - App-specific H key (Chrome)"
   :rules [:!apple_internal :Chrome
    [:h [["dsk_layer" 3] ["dsk_in_modal_layer" 1] [:layer "chrome"]] ["dsk_layer" 0]]
   ]}

  {:des "[Layer 0] Normal - App-specific H key (VS Code)"
   :rules [:!apple_internal :VSCode
    [:h [["dsk_layer" 4] ["dsk_in_modal_layer" 1] {:shell "echo vscode > /tmp/karabiner-layer"}] ["dsk_layer" 0]]
   ]}

  {:des "[Layer 0] Normal - App-specific H key (iTerm/TMUX)"
   :rules [:!apple_internal :iTerm
    ;; h in Normal sends Control+A (tmux prefix) and enters tmux layer
    [:h [:!Ta ["dsk_layer" 5] ["dsk_in_modal_layer" 1] [:layer "tmux"]] ["dsk_layer" 0]]
   ]}

  {:des "[Layer 0] Normal - Disable unmapped keys"
   :rules [:!apple_internal
    ;; In Normal mode, only layer selector keys should work
    ;; Disable all other letter keys to prevent accidental typing (## catches shift variants)
    ;; Active keys: j (Ins), n (escape), m (Label), i (Admin), comma (Comma), l (L), u (Term), h (app-specific), 6 (TTS), y (Wispr)
    [:##a :vk_none ["dsk_layer" 0]]
    [:##b :vk_none ["dsk_layer" 0]]
    [:##c :vk_none ["dsk_layer" 0]]
    [:##d :vk_none ["dsk_layer" 0]]
    [:##e :vk_none ["dsk_layer" 0]]
    [:##f :vk_none ["dsk_layer" 0]]
    [:##g :vk_none ["dsk_layer" 0]]
    [:##k :vk_none ["dsk_layer" 0]]
    [:##o :vk_none ["dsk_layer" 0]]
    [:##p :vk_none ["dsk_layer" 0]]
    [:##q :vk_none ["dsk_layer" 0]]
    [:##r :vk_none ["dsk_layer" 0]]
    [:##s :vk_none ["dsk_layer" 0]]
    [:##t :vk_none ["dsk_layer" 0]]
    [:##v :vk_none ["dsk_layer" 0]]
    [:##w :vk_none ["dsk_layer" 0]]
    [:##x :vk_none ["dsk_layer" 0]]
    [:##z :vk_none ["dsk_layer" 0]]
    ;; Disable brackets
    [:##open_bracket :vk_none ["dsk_layer" 0]]
    [:##close_bracket :vk_none ["dsk_layer" 0]]
    ;; Also disable period, semicolon, slash (not layer selectors) - ## catches shift variants
    [:##period :vk_none ["dsk_layer" 0]]
    [:##semicolon :vk_none ["dsk_layer" 0]]
    [:##slash :vk_none ["dsk_layer" 0]]
    ;; Disable numbers 7-0, backslash, hyphen, quote (6 is TTS trigger)
    [:##quote :vk_none ["dsk_layer" 0]]
    [:##7 :vk_none ["dsk_layer" 0]]
    [:##8 :vk_none ["dsk_layer" 0]]
    [:##9 :vk_none ["dsk_layer" 0]]
    [:##0 :vk_none ["dsk_layer" 0]]
    [:##backslash :vk_none ["dsk_layer" 0]]
    [:##hyphen :vk_none ["dsk_layer" 0]]
    ;; Shift+layer-entry-keys disabled (bare key enters layer, shift should do nothing)
    [{:key :u :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :h :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :j :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :l :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :n :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :m :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [{:key :comma :modi {:mandatory [:shift]}} :vk_none ["dsk_layer" 0]]
    [:##spacebar :vk_none ["dsk_layer" 0]]
    [:page_down :vk_none ["dsk_layer" 0]]
    [:page_up :vk_none ["dsk_layer" 0]]
   ]}

  ;; =====================================================================
  ;; HIGHER LAYER RULES (organized by layer)
  ;; =====================================================================

  {:des "[Layer 14] L-Cmd click handling (regular clicks, exits to Normal)"
   :rules [:!apple_internal
    [:page_down [["dsk_layer" 0] ["dsk_in_modal_layer" 0] {:shell "echo norm > /tmp/karabiner-layer"} {:pkey :button1}] ["dsk_layer" 14]]
    [:page_up [["dsk_layer" 0] ["dsk_in_modal_layer" 0] {:shell "echo norm > /tmp/karabiner-layer"} {:pkey :button2}] ["dsk_layer" 14]]
   ]}

  ;; =====================================================================
  ;; LAYER 1: INS (typing mode)
  ;; =====================================================================
  ;; Submodes: 0=base, 1=shift_mirror_oneshot, 2=shift_oneshot, 3=rcmd_h (delete), 4=rcmd_n (select)

  ;; --- Submode 1: shift_mirror_oneshot (numbers must come before number swap rules) ---
  {:des "[Layer 1 Submode 1] Shift+mirror oneshot numbers"
   :rules [:!apple_internal
    [:6 [:5 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:7 [:4 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:8 [:3 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:9 [:2 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:0 [:1 ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
   ]}

  ;; --- Submode 0: base Ins rules ---
  {:des "[Layer 1 Submode 0] Numbers to symbols (RHS 6-0)"
   :rules [:!apple_internal
    [{:key :6 :modi {:optional [:caps_lock]}} :!S6 ["dsk_layer" 1]]
    [{:key :7 :modi {:optional [:caps_lock]}} :!S7 ["dsk_layer" 1]]
    [{:key :8 :modi {:optional [:caps_lock]}} :!S8 ["dsk_layer" 1]]
    [{:key :9 :modi {:optional [:caps_lock]}} :!S9 ["dsk_layer" 1]]
    [{:key :0 :modi {:optional [:caps_lock]}} :!S0 ["dsk_layer" 1]]
    [{:key :6 :modi {:mandatory [:shift] :optional [:caps_lock]}} :6 ["dsk_layer" 1]]
    [{:key :7 :modi {:mandatory [:shift] :optional [:caps_lock]}} :7 ["dsk_layer" 1]]
    [{:key :8 :modi {:mandatory [:shift] :optional [:caps_lock]}} :8 ["dsk_layer" 1]]
    [{:key :9 :modi {:mandatory [:shift] :optional [:caps_lock]}} :9 ["dsk_layer" 1]]
    [{:key :0 :modi {:mandatory [:shift] :optional [:caps_lock]}} :0 ["dsk_layer" 1]]
   ]}

  {:des "[Layer 1 Submode 0] Shift+up/down = square brackets"
   :rules [:!apple_internal
    [{:key :up_arrow :modi {:mandatory [:shift]}} :open_bracket ["dsk_layer" 1]]
    [{:key :down_arrow :modi {:mandatory [:shift]}} :close_bracket ["dsk_layer" 1]]
   ]}

  {:des "Brackets to command+bracket (in_modal 1)"
   :rules [:!apple_internal
    [{:key :open_bracket :modi {:optional [:caps_lock]}} :!Copen_bracket ["dsk_in_modal_layer" 1]]
    [{:key :close_bracket :modi {:optional [:caps_lock]}} :!Cclose_bracket ["dsk_in_modal_layer" 1]]
    [{:key :open_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :open_bracket ["dsk_in_modal_layer" 1]]
    [{:key :close_bracket :modi {:mandatory [:command] :optional [:caps_lock]}} :close_bracket ["dsk_in_modal_layer" 1]]
   ]}

  {:des "[Layer 1 Submode 0] Backslash = tab"
   :rules [:!apple_internal
    [:backslash :tab ["dsk_layer" 1]]
   ]}

  {:des "[Desktop] Right command + brackets to ctrl-tab navigation"
   :rules [:!apple_internal
    [{:key :open_bracket :modi {:mandatory [:right_command]}} :!TStab]
    [{:key :close_bracket :modi {:mandatory [:right_command]}} :!Ttab]
   ]}

  {:des "[Desktop] Right control + brackets to backspace/delete"
   :rules [:!apple_internal
    [{:key :open_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_or_backspace :modi []}]
    [{:key :close_bracket :modi {:mandatory [:right_control] :optional [:any]}} {:key :delete_forward :modi []}]
   ]}

  
  ;; --- Submode 3: rcmd+H chord (delete) ---
  {:des "[Layer 1 Submode 3] rcmd+H chord (delete)"
   :rules [:!apple_internal
    ;; rcmd+H sets rcmd_h_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :h :modi {:mandatory [:right_command]}} [{:shell ":"} ["dsk_ins_sub_mode" 3]] ["dsk_layer" 1] {:afterup [["dsk_ins_sub_mode" 0]]}]
    ;; While rcmd_h_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!Odelete_or_backspace ["dsk_ins_sub_mode" 3]]      ;; J = del word left
    [{:key :k :modi {:mandatory [:right_command]}} :!Odelete_forward ["dsk_ins_sub_mode" 3]]          ;; K = del word right
    [{:key :m :modi {:mandatory [:right_command]}} :!Cdelete_or_backspace ["dsk_ins_sub_mode" 3]]     ;; M = del to line start
    [{:key :comma :modi {:mandatory [:right_command]}} :!Tk ["dsk_ins_sub_mode" 3]]                   ;; , = del to line end
    [{:key :up_arrow :modi {:mandatory [:right_command]}} :delete_or_backspace ["dsk_ins_sub_mode" 3]] ;; up = del char left
    [{:key :down_arrow :modi {:mandatory [:right_command]}} :delete_forward ["dsk_ins_sub_mode" 3]]   ;; down = del char right
   ]}

  ;; --- Submode 4: rcmd+N chord (select) ---
  {:des "[Layer 1 Submode 4] rcmd+N chord (select)"
   :rules [:!apple_internal
    ;; rcmd+N sets rcmd_n_mode=1, resets on release (shell ":" prevents key passthrough)
    [{:key :n :modi {:mandatory [:right_command]}} [{:shell ":"} ["dsk_ins_sub_mode" 4]] ["dsk_layer" 1] {:afterup [["dsk_ins_sub_mode" 0]]}]
    ;; While rcmd_n_mode=1:
    [{:key :j :modi {:mandatory [:right_command]}} :!SOleft_arrow ["dsk_ins_sub_mode" 4]]             ;; J = sel word left
    [{:key :k :modi {:mandatory [:right_command]}} :!SOright_arrow ["dsk_ins_sub_mode" 4]]            ;; K = sel word right
    [{:key :m :modi {:mandatory [:right_command]}} :!SCleft_arrow ["dsk_ins_sub_mode" 4]]             ;; M = sel to line start
    [{:key :comma :modi {:mandatory [:right_command]}} :!SCright_arrow ["dsk_ins_sub_mode" 4]]        ;; , = sel to line end
    [{:key :up_arrow :modi {:mandatory [:right_command]}} :!Sleft_arrow ["dsk_ins_sub_mode" 4]]       ;; up = sel char left
    [{:key :down_arrow :modi {:mandatory [:right_command]}} :!Sright_arrow ["dsk_ins_sub_mode" 4]]    ;; down = sel char right
   ]}

  {:des "[Layer 1 Submode 0] Arrow navigation with right command"
   :rules [:!apple_internal
    ;; right_command + j = option + left (word left)
    [{:key :j :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:right_option]} ["dsk_layer" 1]]
    ;; right_command + k = option + right (word right)
    [{:key :k :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:right_option]} ["dsk_layer" 1]]
    ;; right_command + m = command + left (line start)
    [{:key :m :modi {:mandatory [:right_command] :optional [:any]}} {:key :left_arrow :modi [:left_command]} ["dsk_layer" 1]]
    ;; right_command + comma = command + right (line end)
    [{:key :comma :modi {:mandatory [:right_command] :optional [:any]}} {:key :right_arrow :modi [:left_command]} ["dsk_layer" 1]]
    ;; right_command + up = left
    [{:key :up_arrow :modi {:mandatory [:right_command] :optional [:any]}} :left_arrow ["dsk_layer" 1]]
    ;; right_command + down = right
    [{:key :down_arrow :modi {:mandatory [:right_command] :optional [:any]}} :right_arrow ["dsk_layer" 1]]
   ]}

  {:des "[Layer 1] Ins Layer - Submode 0 (base typing)"
   :rules [:!apple_internal
    ;; (Entry rules are in Layer 0 section)
    ;; Block Ctrl+J in Ins mode (otherwise it types a newline)
    [{:key :j :modi {:mandatory [:control]}} :vk_none ["dsk_layer" 1]]
    ;; right_control alone exits Ins to Normal
    [:right_control :right_control ["dsk_layer" 1] {:alone [["dsk_layer" 0] ["dsk_in_modal_layer" 0] ["dsk_ins_sub_mode" 0] ["dsk_ins_sub_mode" 0] {:shell "echo norm > /tmp/karabiner-layer"}]}]
    ;; Fn+] (Alt+F12) = enter shift_mirror_oneshot mode
    [:!Of12 [["dsk_ins_sub_mode" 1]] ["dsk_layer" 1]]
    ;; Fn+Space (Alt+F18) = space + shift_oneshot (next letter capitalized)
    [:!Of18 [:spacebar ["dsk_ins_sub_mode" 2]] ["dsk_layer" 1]]
    ;; Fn+Enter (Alt+F17) = Shift+Enter
    [:!Of17 :!Sreturn_or_enter ["dsk_layer" 1]]
    ;; [ = backspace, ] = delete in Ins mode
    [:open_bracket :delete_or_backspace ["dsk_layer" 1]]
    [:close_bracket :delete_forward ["dsk_layer" 1]]
   ]}

  {:des "[Layer 1 Submode 1] Shift+mirror oneshot letters"
   :rules [:!apple_internal
    ;; Top row: Y U I O P → Shift+T R E W Q
    [:y [:!St ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:u [:!Sr ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:i [:!Se ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:o [:!Sw ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:p [:!Sq ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    ;; Home row: H J K L ; → Shift+G F D S A
    [:h [:!Sg ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:j [:!Sf ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:k [:!Sd ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:l [:!Ss ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:semicolon [:!Sa ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    ;; Bottom row: N M , . / → Shift+B V C X Z
    [:n [:!Sb ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
    [:m [:!Sv ["dsk_ins_sub_mode" 0]] ["dsk_ins_sub_mode" 1]]
